@page "/admin-login"
@inject SecureCredentialStorage Credentials
@inject NavigationManager Navigation
@rendermode RenderMode.InteractiveServer

<section class="page-heading">
    <div>
        <p class="eyebrow">Креды телефонов</p>
        <h1>Админ-режим</h1>
    </div>
</section>

<section class="form-panel narrow-panel">
    @if (!string.IsNullOrEmpty(_error))
    {
        <div class="alert alert-danger">@_error</div>
    }

    <div class="field-stack">
        <label>
            <span>Логин администратора телефона</span>
            <input type="text" @bind="_username" autocomplete="username" />
        </label>
        <label>
            <span>Пароль администратора телефона</span>
            <input type="password" @bind="_password" autocomplete="current-password" />
        </label>
    </div>

    <div class="action-row">
        <button class="btn primary" @onclick="OnSubmit">Включить режим</button>
        <button class="btn ghost" @onclick='() => Navigation.NavigateTo("/")'>Отмена</button>
    </div>
</section>

@code {
    private string _username = string.Empty;
    private string _password = string.Empty;
    private string? _error;

    private void OnSubmit()
    {
        if (string.IsNullOrWhiteSpace(_username) || string.IsNullOrWhiteSpace(_password))
        {
            _error = "Введите логин и пароль телефона";
            return;
        }

        Credentials.SetAdminCredentials(_username, _password, TimeSpan.FromMinutes(30));
        Navigation.NavigateTo("/");
    }
}
