@page "/config/{Ip}"
@inject PhoneStore Store
@inject NavigationManager Navigation

<h3>Конфигурация телефона</h3>

@if (_phone == null)
{
    <p>Телефон не найден. <a href="/">Назад</a></p>
}
else
{
    <p><strong>IP:</strong> @_phone.IpAddress</p>
    <p><strong>MAC:</strong> @_phone.MacAddress</p>
    <p><strong>Модель:</strong> @_phone.Model</p>
    <p><strong>Аккаунт:</strong> @_phone.Account</p>

    <div class="alert alert-info">
        Конфигуратор через API будет реализован позже.
    </div>

    <button @onclick="OpenWeb">Открыть веб-интерфейс</button>
    <button @onclick="GoBack">Назад</button>
}

@code {
    [Parameter] public string Ip { get; set; } = string.Empty;
    private PhoneInfo? _phone;

    protected override void OnInitialized()
    {
        _phone = Store.GetByIp(Ip);
    }

    private void OpenWeb() => Navigation.NavigateTo($"http://{_phone?.IpAddress}");
    private void GoBack() => Navigation.NavigateTo("/");
}