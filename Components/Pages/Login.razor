@page "/login"
@inject SecureCredentialStorage Credentials
@inject NavigationManager Navigation
@rendermode RenderMode.InteractiveServer

<h3>Авторизация Yealink</h3>

@if (!string.IsNullOrEmpty(_error))
{
    <div class="alert alert-danger">@_error</div>
}

<div>
    <label>Логин:</label>
    <input type="text" @bind="_username" />
</div>
<div>
    <label>Пароль:</label>
    <input type="password" @bind="_password" />
</div>
<button @onclick="OnSubmit">Сохранить</button>

@code {
    private string _username = string.Empty;
    private string _password = string.Empty;
    private string? _error;

    private void OnSubmit()
    {
        if (string.IsNullOrWhiteSpace(_username) || string.IsNullOrWhiteSpace(_password))
        {
            _error = "Введите логин и пароль";
            return;
        }

        Credentials.SetUserCredentials(_username, _password);
        Navigation.NavigateTo("/");
    }
}
