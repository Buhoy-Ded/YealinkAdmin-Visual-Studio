@page "/"
@using System.Net
@inject YealinkScanner Scanner
@inject PhoneStore Store
@inject SecureCredentialStorage Credentials
@inject IConfiguration Config
@inject NavigationManager Navigation
@inject YealinkApiClient ApiClient
@inject YealinkStatusClient StatusClient
@inject YealinkConfigManager ConfigManager
@implements IDisposable
@rendermode RenderMode.InteractiveServer

<section class="page-heading">
    <div>
        <p class="eyebrow">Инвентарь</p>
        <h1>Телефоны Yealink</h1>
    </div>
</section>

<section class="summary-grid">
    <div class="metric">
        <span>Всего</span>
        <strong>@_phones.Count</strong>
    </div>
    <div class="metric">
        <span>Онлайн</span>
        <strong>@_phones.Count(p => p.IsOnline)</strong>
    </div>
    <div class="metric warning">
        <span>Action URI</span>
        <strong>@_phones.Count(p => p.IsForbidden)</strong>
    </div>
    <div class="metric">
        <span>Выбрано</span>
        <strong>@_selectedPhones.Count</strong>
    </div>
</section>

<section class="command-bar">
    <div class="command-group">
        <button class="btn primary" @onclick="StartScanNew" disabled="@(_scanning || !Credentials.IsAdminConfigured)">
            @(_scanning ? "Сканирование..." : "Сканировать новые")
        </button>
        <button class="btn" @onclick="StartScanAll" disabled="@(_scanning || !Credentials.IsAdminConfigured)">
            Обновить список
        </button>
        <button class="btn secondary" @onclick="RebootSelected" disabled="@(!_selectedPhones.Any() || _scanning || _rebooting || !Credentials.IsAdminConfigured)">
            @(_rebooting ? "Перезагрузка..." : "Перезагрузить")
        </button>
        <button class="btn danger" @onclick="DeleteSelected" disabled="@(!_selectedPhones.Any() || _scanning)">
            Удалить выбранные
        </button>
    </div>
    @*---Добавил, потому что так красивее---*@
    <section class="manual-check">
        <input type="text" placeholder="IP для проверки" @bind="_manualIp" />
        <button class="btn" @onclick="CheckManualIp" disabled="@(_checkingManual || !Credentials.IsAdminConfigured)">Проверить</button>
    </section>
    @*---               End              ---*@
    <div class="search-box">
        <input type="search" placeholder="Поиск по IP, MAC, серийнику, модели или аккаунту" @bind="_searchText" @bind:event="oninput" />
    </div>
</section>

@if (!Credentials.IsAdminConfigured)
{
    <div class="alert alert-info">
        Сейчас открыт режим просмотра: список, кэш и поиск доступны без пароля. Сканирование, проверка IP и управление телефонами требуют админ-креды телефонов.
    </div>
}

@if (_scanning)
{
    <section class="diagnostics">
        <div class="diagnostics-row">
            <span>Найдено: @_foundCount</span>
            <span>Старт: @_scanStart.ToLocalTime().ToString("HH:mm:ss")</span>
        </div>
    </section>
}

@if (!string.IsNullOrEmpty(_lastScanLog))
{
    <div class="alert alert-info">@_lastScanLog</div>
}

@* <section class="manual-check">
    <input type="text" placeholder="IP для проверки" @bind="_manualIp" />
    <button class="btn" @onclick="CheckManualIp" disabled="@(_checkingManual || !Credentials.IsAdminConfigured)">Проверить</button>
</section> *@

@if (!string.IsNullOrEmpty(_manualResult))
{
    <pre class="diagnostics">@_manualResult</pre>
}

@if (FilteredPhones.Any())
{
    <section class="table-panel">
        <table class="data-table">
            <thead>
                <tr>
                    <th class="select-cell"><input type="checkbox" @onclick="ToggleSelectAll" /></th>
                    <th @onclick='() => SortBy(nameof(PhoneInfo.IpAddress))'>IP @SortIcon(nameof(PhoneInfo.IpAddress))</th>
                    <th @onclick='() => SortBy(nameof(PhoneInfo.Model))'>Модель @SortIcon(nameof(PhoneInfo.Model))</th>
                    <th @onclick='() => SortBy(nameof(PhoneInfo.MacAddress))'>MAC @SortIcon(nameof(PhoneInfo.MacAddress))</th>
                    <th @onclick='() => SortBy(nameof(PhoneInfo.SerialNumber))'>Серийник @SortIcon(nameof(PhoneInfo.SerialNumber))</th>
                    <th @onclick='() => SortBy(nameof(PhoneInfo.Account))'>Аккаунт @SortIcon(nameof(PhoneInfo.Account))</th>
                    <th @onclick='() => SortBy(nameof(PhoneInfo.IsOnline))'>Статус @SortIcon(nameof(PhoneInfo.IsOnline))</th>
                    <th @onclick='() => SortBy(nameof(PhoneInfo.LastSeen))'>Последняя проверка @SortIcon(nameof(PhoneInfo.LastSeen))</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var phone in FilteredPhones)
                {
                    <tr class="@(phone.IsForbidden ? "forbidden-row" : "")">
                        <td class="select-cell">
                            <input type="checkbox" checked="@_selectedPhones.Contains(phone.IpAddress)" @onclick="() => ToggleSelect(phone.IpAddress)" />
                        </td>
                        <td><a class="strong-link" href="/config/@phone.IpAddress">@phone.IpAddress</a></td>
                        <td>@(phone.Model ?? "Не определена")</td>
                        <td>@DisplayValue(phone.MacAddress)</td>
                        <td>@DisplayValue(phone.SerialNumber)</td>
                        <td>@phone.Account</td>
                        <td>
                            @if (phone.IsForbidden)
                            {
                                <span class="status-chip warning">Нужен Action URI</span>
                            }
                            else if (phone.IsOnline)
                            {
                                <span class="status-chip good">Онлайн</span>
                            }
                            else
                            {
                                <span class="status-chip muted">Из кэша</span>
                            }
                        </td>
                        <td>@phone.LastSeen.ToLocalTime().ToString("dd.MM HH:mm:ss")</td>
                    </tr>
                }
            </tbody>
        </table>
    </section>
    <p class="table-note">Показано: @FilteredPhones.Count() из @_phones.Count</p>
}
else if (!_scanning)
{
    <section class="empty-state">
        <h2>Телефоны пока не найдены</h2>
        <p>Войдите в админ-режим и запустите сканирование.</p>
    </section>
}

@code {
    private List<PhoneInfo> _phones = new();
    private bool _scanning;
    private int _foundCount;
    private DateTime _scanStart;
    private string _searchText = string.Empty;
    private string _sortColumn = nameof(PhoneInfo.IpAddress);
    private bool _sortAscending = true;
    private HashSet<string> _selectedPhones = new();

    private string _lastScanLog = string.Empty;
    private string _manualIp = string.Empty;
    private bool _checkingManual;
    private string _manualResult = string.Empty;
    private bool _rebooting;

    private IEnumerable<PhoneInfo> FilteredPhones
    {
        get
        {
            var query = _phones.AsEnumerable();
            if (!string.IsNullOrWhiteSpace(_searchText))
            {
                var search = _searchText.Trim();
                query = query.Where(p =>
                    p.IpAddress.Contains(search, StringComparison.OrdinalIgnoreCase) ||
                    p.MacAddress.Contains(search, StringComparison.OrdinalIgnoreCase) ||
                    p.SerialNumber.Contains(search, StringComparison.OrdinalIgnoreCase) ||
                    (p.Model?.Contains(search, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    p.Account.Contains(search, StringComparison.OrdinalIgnoreCase));
            }

            query = _sortColumn switch
            {
                nameof(PhoneInfo.IpAddress) => _sortAscending
                    ? query.OrderBy(p => IPAddress.Parse(p.IpAddress).GetAddressBytes(), new ByteArrayComparer())
                    : query.OrderByDescending(p => IPAddress.Parse(p.IpAddress).GetAddressBytes(), new ByteArrayComparer()),
                nameof(PhoneInfo.Model) => _sortAscending
                    ? query.OrderBy(p => p.Model)
                    : query.OrderByDescending(p => p.Model),
                nameof(PhoneInfo.MacAddress) => _sortAscending
                    ? query.OrderBy(p => p.MacAddress)
                    : query.OrderByDescending(p => p.MacAddress),
                nameof(PhoneInfo.SerialNumber) => _sortAscending
                    ? query.OrderBy(p => p.SerialNumber)
                    : query.OrderByDescending(p => p.SerialNumber),
                nameof(PhoneInfo.Account) => _sortAscending
                    ? query.OrderBy(p => p.Account)
                    : query.OrderByDescending(p => p.Account),
                nameof(PhoneInfo.IsOnline) => _sortAscending
                    ? query.OrderBy(p => p.IsOnline)
                    : query.OrderByDescending(p => p.IsOnline),
                nameof(PhoneInfo.LastSeen) => _sortAscending
                    ? query.OrderBy(p => p.LastSeen)
                    : query.OrderByDescending(p => p.LastSeen),
                _ => query
            };

            return query;
        }
    }

    protected override void OnInitialized()
    {
        Credentials.Changed += OnCredentialsChanged;
        _phones = Store.All.ToList();
    }

    private void SortBy(string column)
    {
        if (_sortColumn == column)
            _sortAscending = !_sortAscending;
        else
        {
            _sortColumn = column;
            _sortAscending = true;
        }
    }

    private string SortIcon(string column) => _sortColumn == column
        ? (_sortAscending ? "↑" : "↓")
        : "";

    private static string DisplayValue(string? value) =>
        string.IsNullOrWhiteSpace(value) || value.Equals("unknown", StringComparison.OrdinalIgnoreCase)
            ? "-"
            : value;

    private void ToggleSelect(string ip)
    {
        if (!_selectedPhones.Add(ip))
            _selectedPhones.Remove(ip);
    }

    private void ToggleSelectAll()
    {
        var filtered = FilteredPhones.ToList();
        if (_selectedPhones.Count == filtered.Count)
            _selectedPhones.Clear();
        else
            _selectedPhones = new HashSet<string>(filtered.Select(p => p.IpAddress));
    }

    private async Task DeleteSelected()
    {
        foreach (var ip in _selectedPhones)
            Store.Remove(ip);

        _selectedPhones.Clear();
        _phones = Store.All.ToList();
        await Store.SaveAsync();
    }

    private async Task RebootSelected()
    {
        var creds = Credentials.GetAdminCredentials();
        if (creds == null)
        {
            _lastScanLog = "Требуется админ-режим.";
            return;
        }

        var selectedIps = _selectedPhones.ToList();
        if (selectedIps.Count == 0)
            return;

        _rebooting = true;
        _lastScanLog = $"Отправка команды reboot: {selectedIps.Count} телефонов...";
        await InvokeAsync(StateHasChanged);

        var success = 0;
        var failed = new List<string>();

        await Parallel.ForEachAsync(selectedIps, new ParallelOptions { MaxDegreeOfParallelism = 8 }, async (ip, ct) =>
        {
            try
            {
                if (await ConfigManager.RebootAsync(ip, creds.Value.username, creds.Value.password))
                {
                    Interlocked.Increment(ref success);
                }
                else
                {
                    lock (failed)
                        failed.Add(ip);
                }
            }
            catch
            {
                lock (failed)
                    failed.Add(ip);
            }
        });

        _rebooting = false;
        _lastScanLog = failed.Count == 0
            ? $"Команда reboot отправлена: {success}."
            : $"Команда reboot отправлена: {success}. Ошибки: {failed.Count} ({string.Join(", ", failed.Take(8))}{(failed.Count > 8 ? ", ..." : "")})";

        await InvokeAsync(StateHasChanged);
    }

    private async Task StartScanNew()
    {
        await ScanInternal(scanExisting: false);
    }

    private async Task StartScanAll()
    {
        var cachedConfig = Store.All
            .Where(p => (p.ConfigFields?.Count ?? 0) > 0)
            .ToDictionary(p => p.IpAddress, p => p.ConfigFields, StringComparer.OrdinalIgnoreCase);

        Store.Clear();
        _phones = new();
        await InvokeAsync(StateHasChanged);
        await ScanInternal(scanExisting: true, cachedConfig);
    }

    private async Task ScanInternal(bool scanExisting, Dictionary<string, Dictionary<string, string>>? cachedConfig = null)
    {
        _scanning = true;
        _foundCount = 0;
        _lastScanLog = string.Empty;
        _scanStart = DateTime.UtcNow;
        await InvokeAsync(StateHasChanged);

        var subnets = Config.GetSection("Yealink:Subnets").Get<string[]>() ?? Array.Empty<string>();
        var creds = Credentials.GetAdminCredentials();

        if (creds == null)
        {
            _lastScanLog = "Требуется админ-режим.";
            _scanning = false;
            await InvokeAsync(StateHasChanged);
            return;
        }

        try
        {
            await foreach (var phone in Scanner.ScanAsync(subnets, scanExisting))
            {
                if ((phone.ConfigFields?.Count ?? 0) == 0 &&
                    cachedConfig != null &&
                    cachedConfig.TryGetValue(phone.IpAddress, out var fields))
                {
                    phone.ConfigFields = new Dictionary<string, string>(fields, StringComparer.OrdinalIgnoreCase);
                }

                _foundCount++;
                var existingIndex = _phones.FindIndex(p =>
                    p.IpAddress.Equals(phone.IpAddress, StringComparison.OrdinalIgnoreCase));
                if (existingIndex >= 0)
                    _phones[existingIndex] = phone;
                else
                    _phones.Add(phone);

                await InvokeAsync(StateHasChanged);
            }

            _lastScanLog = $"Сканирование завершено. Найдено: {_foundCount}";
        }
        catch (Exception ex)
        {
            _lastScanLog = $"Ошибка сканирования: {ex.Message}";
        }

        _phones = Store.All.ToList();
        _scanning = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task CheckManualIp()
    {
        if (string.IsNullOrWhiteSpace(_manualIp) || !IPAddress.TryParse(_manualIp, out _))
        {
            _manualResult = "Введите корректный IP.";
            return;
        }

        var creds = Credentials.GetAdminCredentials();
        if (creds == null)
        {
            _manualResult = "Требуется админ-режим.";
            return;
        }

        _checkingManual = true;
        _manualResult = $"Проверка {_manualIp}...";
        await InvokeAsync(StateHasChanged);

        try
        {
            var response = await ApiClient.QueryAsync(_manualIp, creds.Value.username, creds.Value.password);
            if (response == null)
            {
                _manualResult = $"phonecfg не дал данных от {_manualIp}. Пробую web status API...\r\n";

                try
                {
                    var statusResult = await StatusClient.GetStatusAsync(_manualIp, creds.Value.username, creds.Value.password);
                    _manualResult += $"Status API ответил.\r\nПолей статуса: {statusResult.Fields.Count}\r\n";
                    foreach (var kvp in statusResult.Fields.Take(14))
                    {
                        _manualResult += $"{kvp.Key}: {kvp.Value}\r\n";
                    }
                }
                catch (Exception ex)
                {
                    _manualResult += $"Status API тоже не ответил: {ex.Message}";
                }
            }
            else if (response == "__FORBIDDEN__")
            {
                _manualResult = "403 Forbidden. Пробую RSA-логин и страницу статуса...";

                try
                {
                    var statusResult = await StatusClient.GetStatusAsync(_manualIp, creds.Value.username, creds.Value.password);
                    _manualResult = $"RSA-логин выполнен.\r\nПолей статуса: {statusResult.Fields.Count}\r\n";
                    foreach (var kvp in statusResult.Fields.Take(10))
                    {
                        _manualResult += $"{kvp.Key}: {kvp.Value}\r\n";
                    }
                }
                catch (Exception ex)
                {
                    _manualResult += $"\r\nRSA-логин не удался: {ex.Message}";
                }
            }
            else
            {
                var firmware = YealinkParser.GetValue(response, "FirmwareVersion");
                var mac = YealinkParser.GetValue(response, "MACAddress");
                _manualResult = $"Ответ получен.\r\nFirmware: {firmware ?? "не найдено"}\r\nMAC: {mac ?? "не найдено"}";
            }
        }
        catch (Exception ex)
        {
            _manualResult = $"Исключение: {ex.GetType().Name}: {ex.Message}";
        }

        _checkingManual = false;
        await InvokeAsync(StateHasChanged);
    }

    private void OnCredentialsChanged()
    {
        _phones = Store.All.ToList();
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Credentials.Changed -= OnCredentialsChanged;
    }

    private class ByteArrayComparer : IComparer<byte[]>
    {
        public int Compare(byte[]? x, byte[]? y)
        {
            if (x == null || y == null) return 0;
            for (int i = 0; i < Math.Min(x.Length, y.Length); i++)
            {
                if (x[i] != y[i]) return x[i].CompareTo(y[i]);
            }
            return x.Length.CompareTo(y.Length);
        }
    }
}
