@page "/"
@using System.Net
@inject YealinkScanner Scanner
@inject PhoneStore Store
@inject SecureCredentialStorage Credentials
@inject IConfiguration Config
@inject NavigationManager Navigation
@inject YealinkApiClient ApiClient
@inject YealinkStatusClient StatusClient
@rendermode RenderMode.InteractiveServer

<h3>Телефоны Yealink</h3>

@if (!Credentials.IsUserConfigured)
{
    <div class="alert alert-warning">
        <a href="/login">Введите логин и пароль</a> для работы с приложением.
    </div>
}
else if (!Credentials.IsAdminConfigured)
{
    <div class="toolbar">
        <button @onclick="ShowAdminLogin">Войти как администратор</button>
        <input type="text" placeholder="Поиск..." @bind="_searchText" @bind:event="oninput" />
    </div>
    <p>Для сканирования и управления телефонами требуется авторизация администратора.</p>
}
else
{
    <div class="toolbar">
        <button @onclick="StartScanNew" disabled="@_scanning">
            @(_scanning ? "Сканирование..." : "Scan Now")
        </button>
        <button @onclick="StartScanAll" disabled="@_scanning">
            @(_scanning ? "Сканирование..." : "Update")
        </button>
        <button @onclick="NavigateToNew" disabled="@_scanning">New</button>
        <button @onclick="DeleteSelected" disabled="@(!_selectedPhones.Any())">Delete</button>
        <button @onclick="AdminLogout">Выйти из админ-режима</button>
        <input type="text" placeholder="Поиск..." @bind="_searchText" @bind:event="oninput" />
    </div>

    @if (_scanning)
    {
        <div class="diagnostics">
            <div class="diagnostics-row">
                <span>Проверено: @_statsChecked</span>
                <span>Ответили: @_statsResponded</span>
                <span>401 Unauthorized: @_statsUnauthorized</span>
                <span>403 Forbidden: @_statsForbidden</span>
                <span>Timeout/Error: @_statsError</span>
                <span>Найдено телефонов: @_foundCount</span>
            </div>
        </div>
    }

    @if (!string.IsNullOrEmpty(_lastScanLog))
    {
        <div class="alert alert-info">
            @_lastScanLog
        </div>
    }

    <div class="toolbar" style="margin-top: 10px;">
        <input type="text" placeholder="IP для проверки..." @bind="_manualIp" />
        <button @onclick="CheckManualIp" disabled="@_checkingManual">Проверить IP</button>
    </div>

    @if (!string.IsNullOrEmpty(_manualResult))
    {
        <pre class="diagnostics">@_manualResult</pre>
    }
}

@if (FilteredPhones.Any())
{
    <table>
        <thead>
            <tr>
                <th><input type="checkbox" @onclick="ToggleSelectAll" /></th>
                <th @onclick='() => SortBy(nameof(PhoneInfo.IpAddress))'>IP @SortIcon(nameof(PhoneInfo.IpAddress))</th>
                <th @onclick='() => SortBy(nameof(PhoneInfo.Model))'>Модель @SortIcon(nameof(PhoneInfo.Model))</th>
                <th @onclick='() => SortBy(nameof(PhoneInfo.Account))'>Аккаунт @SortIcon(nameof(PhoneInfo.Account))</th>
                <th @onclick='() => SortBy(nameof(PhoneInfo.IsOnline))'>Статус @SortIcon(nameof(PhoneInfo.IsOnline))</th>
                <th @onclick='() => SortBy(nameof(PhoneInfo.LastSeen))'>Последняя проверка @SortIcon(nameof(PhoneInfo.LastSeen))</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var phone in FilteredPhones)
            {
                <tr class="@(phone.IsForbidden ? "forbidden-row" : "")">
                    <td><input type="checkbox" checked="@_selectedPhones.Contains(phone.IpAddress)" @onclick="() => ToggleSelect(phone.IpAddress)" /></td>
                    <td><a href="/config/@phone.IpAddress">@phone.IpAddress</a></td>
                    <td>@phone.Model</td>
                    <td>@phone.Account</td>
                    <td>
                        @if (phone.IsForbidden)
                        {
                            <span>⚠️ 403</span>
                        }
                        else
                        {
                            <span>@(phone.IsOnline ? "Онлайн" : "Из кэша")</span>
                        }
                    </td>
                    <td>@phone.LastSeen.ToLocalTime().ToString("HH:mm:ss")</td>
                </tr>
            }
        </tbody>
    </table>
    <p>Всего: @FilteredPhones.Count() из @Store.All.Count()</p>
}
else if (!_scanning)
{
    <p>Нет данных. Нажмите "Scan Now" для сканирования сети.</p>
}

@if (_showAdminLogin)
{
    <div class="modal">
        <div class="modal-content">
            <h4>Администраторский доступ</h4>
            <div>
                <label>Логин:</label>
                <input type="text" @bind="_adminUsername" />
            </div>
            <div>
                <label>Пароль:</label>
                <input type="password" @bind="_adminPassword" />
            </div>
            <button @onclick="AdminLogin">Войти</button>
            <button @onclick='() => _showAdminLogin = false'>Отмена</button>
        </div>
    </div>
}

@code {
    private List<PhoneInfo> _phones = new ();
    private bool _scanning;
    private int _foundCount;
    private int _statsChecked;
    private int _statsResponded;
    private int _statsUnauthorized;
    private int _statsForbidden;
    private int _statsError;
    private DateTime _scanStart;
    private string _searchText = string.Empty;
    private string _sortColumn = nameof(PhoneInfo.IpAddress);
    private bool _sortAscending = true;
    private HashSet<string> _selectedPhones = new();

    private bool _showAdminLogin;
    private string _adminUsername = string.Empty;
    private string _adminPassword = string.Empty;

    private string _lastScanLog = string.Empty;
    private string _manualIp = string.Empty;
    private bool _checkingManual;
    private string _manualResult = string.Empty;

    private IEnumerable<PhoneInfo> FilteredPhones
    {
        get
        {
            var query = _phones.AsEnumerable();
            if (!string.IsNullOrWhiteSpace(_searchText))
            {
                var search = _searchText.Trim();
                query = query.Where(p =>
                    p.IpAddress.Contains(search, StringComparison.OrdinalIgnoreCase) ||
                    (p.Model?.Contains(search, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    p.Account.Contains(search, StringComparison.OrdinalIgnoreCase));
            }

            query = _sortColumn switch
            {
                nameof(PhoneInfo.IpAddress) => _sortAscending
                    ? query.OrderBy(p => IPAddress.Parse(p.IpAddress).GetAddressBytes(), new ByteArrayComparer())
                    : query.OrderByDescending(p => IPAddress.Parse(p.IpAddress).GetAddressBytes(), new ByteArrayComparer()),
                nameof(PhoneInfo.Model) => _sortAscending
                    ? query.OrderBy(p => p.Model)
                    : query.OrderByDescending(p => p.Model),
                nameof(PhoneInfo.Account) => _sortAscending
                    ? query.OrderBy(p => p.Account)
                    : query.OrderByDescending(p => p.Account),
                nameof(PhoneInfo.IsOnline) => _sortAscending
                    ? query.OrderBy(p => p.IsOnline)
                    : query.OrderByDescending(p => p.IsOnline),
                nameof(PhoneInfo.LastSeen) => _sortAscending
                    ? query.OrderBy(p => p.LastSeen)
                    : query.OrderByDescending(p => p.LastSeen),
                _ => query
            };

            return query;
        }
    }

    protected override void OnInitialized()
    {
        _phones = Store.All.ToList();
    }

    private void SortBy(string column)
    {
        if (_sortColumn == column)
            _sortAscending = !_sortAscending;
        else
        {
            _sortColumn = column;
            _sortAscending = true;
        }
    }

    private string SortIcon(string column) => _sortColumn == column
        ? (_sortAscending ? "▲" : "▼")
        : "";

    private void ToggleSelect(string ip)
    {
        if (_selectedPhones.Contains(ip))
            _selectedPhones.Remove(ip);
        else
            _selectedPhones.Add(ip);
    }

    private void ToggleSelectAll()
    {
        if (_selectedPhones.Count == FilteredPhones.Count())
            _selectedPhones.Clear();
        else
            _selectedPhones = new HashSet<string>(FilteredPhones.Select(p => p.IpAddress));
    }

    private void DeleteSelected()
    {
        foreach (var ip in _selectedPhones)
            Store.Remove(ip);

        _selectedPhones.Clear();
        _phones = Store.All.ToList();
    }

    private void NavigateToNew()
    {
        Navigation.NavigateTo("/config/new");
    }

    private void ShowAdminLogin() => _showAdminLogin = true;

    private void AdminLogin()
    {
        if (!string.IsNullOrWhiteSpace(_adminUsername) && !string.IsNullOrWhiteSpace(_adminPassword))
        {
            Credentials.SetAdminCredentials(_adminUsername, _adminPassword, TimeSpan.FromMinutes(30));
            _showAdminLogin = false;
            _phones = Store.All.ToList();
        }
    }

    private void AdminLogout()
    {
        Credentials.ClearAdminCredentials();
        _phones = Store.All.ToList();
    }

    private async Task StartScanNew()
    {
        await ScanInternal(scanExisting: false);
    }

    private async Task StartScanAll()
    {
        Store.Clear();
        _phones = new();
        await InvokeAsync(StateHasChanged);
        await ScanInternal(scanExisting: true);
    }

    private async Task ScanInternal(bool scanExisting)
    {
        _scanning = true;
        _foundCount = 0;
        _statsChecked = 0;
        _statsResponded = 0;
        _statsUnauthorized = 0;
        _statsForbidden = 0;
        _statsError = 0;
        _lastScanLog = string.Empty;
        _scanStart = DateTime.UtcNow;
        await InvokeAsync(StateHasChanged);

        var subnets = Config.GetSection("Yealink:Subnets").Get<string[]>() ?? Array.Empty<string>();
        var creds = Credentials.GetAdminCredentials();

        if (creds == null)
        {
            _lastScanLog = "Admin credentials not available";
            _scanning = false;
            await InvokeAsync(StateHasChanged);
            return;
        }

        try
        {
            await foreach (var phone in Scanner.ScanAsync(subnets, scanExisting))
            {
                _foundCount++;
                _phones.Add(phone);
                await InvokeAsync(StateHasChanged);
            }

            _lastScanLog = $"Сканирование завершено. Найдено: {_foundCount}";
        }
        catch (Exception ex)
        {
            _lastScanLog = $"Ошибка сканирования: {ex.Message}";
        }

        _phones = Store.All.ToList();
        _scanning = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task CheckManualIp()
    {
        if (string.IsNullOrWhiteSpace(_manualIp) || !IPAddress.TryParse(_manualIp, out _))
        {
            _manualResult = "Введите корректный IP";
            return;
        }

        var creds = Credentials.GetAdminCredentials();
        if (creds == null)
        {
            _manualResult = "Требуется admin-авторизация";
            return;
        }

        _checkingManual = true;
        _manualResult = $"Проверка {_manualIp}...";
        await InvokeAsync(StateHasChanged);

        try
        {
            // Пробуем старый endpoint
            var response = await ApiClient.QueryAsync(_manualIp, creds.Value.username, creds.Value.password);
            if (response == null)
            {
                _manualResult = $"Нет ответа от {_manualIp}\r\n- Телефон выключен/недоступен\r\n- Неверный логин/пароль\r\n- Брандмауэр блокирует HTTPS";
            }
            else if (response == "__FORBIDDEN__")
            {
                _manualResult = $"403 Forbidden — Action URI отключён\r\nПробуем RSA-логин + Status Page...";

                try
                {
                    var statusResult = await StatusClient.GetStatusAsync(_manualIp, creds.Value.username, creds.Value.password);
                    _manualResult = $"RSA-логин OK!\r\n\rНайдено полей: {statusResult.Fields.Count}\r\n";
                    foreach (var kvp in statusResult.Fields.Take(10))
                    {
                        _manualResult += $"{kvp.Key}: {kvp.Value}\r\n";
                    }
                }
                catch (Exception ex)
                {
                    _manualResult += $"\r\n\rRSA-логин не удался: {ex.Message}";
                }
            }
            else
            {
                var firmware = YealinkParser.GetValue(response, "FirmwareVersion");
                var mac = YealinkParser.GetValue(response, "MACAddress");
                _manualResult = $"Ответ получен!\r\nFirmware: {firmware ?? "не найдено"}\r\nMAC: {mac ?? "не найдено"}\r\n\r\nПервые 500 символов:\r\n{response[..Math.Min(500, response.Length)]}";
            }
        }
        catch (Exception ex)
        {
            _manualResult = $"Исключение: {ex.GetType().Name}: {ex.Message}";
        }

        _checkingManual = false;
        await InvokeAsync(StateHasChanged);
    }

    private class ByteArrayComparer : IComparer<byte[]>
    {
        public int Compare(byte[]? x, byte[]? y)
        {
            if (x == null || y == null) return 0;
            for (int i = 0; i < Math.Min(x.Length, y.Length); i++)
            {
                if (x[i] != y[i]) return x[i].CompareTo(y[i]);
            }
            return x.Length.CompareTo(y.Length);
        }
    }
}