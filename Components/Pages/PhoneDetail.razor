@page "/config/{Ip}"
@inject PhoneStore Store
@inject NavigationManager Navigation
@inject SecureCredentialStorage Credentials
@inject YealinkStatusClient StatusClient
@inject YealinkConfigManager ConfigManager
@inject YealinkModernApiClient ModernApiClient
@rendermode RenderMode.InteractiveServer

@if (_phone == null)
{
    <section class="empty-state">
        <h1>Телефон не найден</h1>
        <p>Проверьте адрес или вернитесь к списку телефонов.</p>
        <button class="btn primary" @onclick="GoBack">К списку</button>
    </section>
}
else
{
    <section class="page-heading">
        <div>
            <p class="eyebrow">Телефон</p>
            <h1>@_phone.IpAddress</h1>
        </div>
        <div class="heading-actions">
            <button class="btn ghost" @onclick="GoBack">Назад</button>
            <button class="btn" @onclick="OpenWebInterface">Веб-интерфейс</button>
        </div>
    </section>

    <section class="device-strip">
        <div>
            <span>Модель</span>
            <strong>@(_phone.Model ?? "Не определена")</strong>
        </div>
        <div>
            <span>MAC</span>
            <strong>@_phone.MacAddress</strong>
        </div>
        <div>
            <span>Серийник</span>
            <strong>@DisplayValue(_phone.SerialNumber)</strong>
        </div>
        <div>
            <span>Аккаунт</span>
            <strong>@_phone.Account</strong>
        </div>
        <div>
            <span>Состояние</span>
            @if (_phone.IsForbidden)
            {
                <strong class="text-warning">Нужен Action URI</strong>
            }
            else
            {
                <strong>@(_phone.IsOnline ? "Онлайн" : "Из кэша")</strong>
            }
        </div>
    </section>

    @if (!Credentials.IsAdminConfigured)
    {
        <div class="alert alert-info">
            Для загрузки статуса, сохранения и импорта конфигурации нужен админ-доступ.
        </div>
    }

    <div class="tabs">
        <button class="@(_activeTab == "status" ? "active" : "")" @onclick='() => _activeTab = "status"'>Status</button>
        <button class="@(_activeTab == "config" ? "active" : "")" @onclick='() => _activeTab = "config"'>Config</button>
    </div>

    @if (_activeTab == "status")
    {
        <section class="detail-panel">
            <div class="panel-title-row">
                <div>
                    <h2>Состояние телефона</h2>
                    <p>Основные параметры устройства и регистрации.</p>
                </div>
                <button class="btn primary" @onclick="LoadStatusSmart" disabled="@(_loadingStatus || !Credentials.IsAdminConfigured)">
                    @(_loadingStatus ? "Загрузка..." : "Обновить")
                </button>
            </div>

            @if (_statusError != null)
            {
                <div class="alert alert-danger">@_statusError</div>
            }

            <div class="status-layout">
                @foreach (var section in StatusSections)
                {
                    <section class="status-block">
                        <h3>@section.Title</h3>
                        @foreach (var row in section.Rows)
                        {
                            <div class="kv-row">
                                <span>@row.Label</span>
                                <strong>@row.Value</strong>
                            </div>
                        }
                    </section>
                }
            </div>

            @if (!string.IsNullOrEmpty(_rawHtmlPreview))
            {
                <details class="debug-details">
                    <summary>Сырой HTML</summary>
                    <pre class="diagnostics">@_rawHtmlPreview</pre>
                </details>
            }
        </section>
    }
    else if (_activeTab == "config")
    {
        <section class="detail-panel">
            <div class="panel-title-row">
                <div>
                    <h2>Конфигурация линии</h2>
                    <p>Параметры будут использоваться для генерации и загрузки .cfg.</p>
                </div>
                <div class="action-row">
                    <button class="btn" @onclick="LoadAccountConfigFromWeb" disabled="@(_loadingAccountConfig || !Credentials.IsAdminConfigured)">
                        @(_loadingAccountConfig ? "Загрузка..." : "Загрузить из телефона")
                    </button>
                    <button class="btn primary" @onclick="SaveConfig" disabled="@(_savingConfig || !Credentials.IsAdminConfigured)">
                        @(_savingConfig ? "Сохранение..." : "Сохранить")
                    </button>
                </div>
            </div>

            @if (_phone.IsForbidden)
            {
                <div class="alert alert-warning">
                    Action URI отключён. Импорт готового .cfg может быть надёжнее, чем управление через web API.
                </div>
            }

            <div class="config-layout">
                <section class="form-panel">
                    <h3>Линия</h3>
                    <div class="form-grid">
                        <label class="switch-row">
                            <span>Активная линия <span class="dirty-mark">@DirtyMark("LineEnabled")</span></span>
                            <input type="checkbox" @bind="_lineEnabled" />
                        </label>
                        <label>
                            <span>Лейбл <span class="dirty-mark">@DirtyMark("LineLabel")</span></span>
                            <input type="text" @bind="_lineLabel" />
                        </label>
                        <label>
                            <span>Отображаемое имя <span class="dirty-mark">@DirtyMark("DisplayName")</span></span>
                            <input type="text" @bind="_displayName" />
                        </label>
                        <label>
                            <span>Имя регистрации <span class="dirty-mark">@DirtyMark("RegisterName")</span></span>
                            <input type="text" @bind="_registerName" />
                        </label>
                        <label>
                            <span>Имя пользователя <span class="dirty-mark">@DirtyMark("UserName")</span></span>
                            <input type="text" @bind="_userName" />
                        </label>
                        <label>
                            <span>Пароль <span class="dirty-mark">@DirtyMark("Password")</span></span>
                            <input type="password" @bind="_password" placeholder="••••••••" />
                        </label>
                    </div>
                </section>

                <section class="form-panel">
                    <h3>SIP-сервер 1</h3>
                    <div class="form-grid">
                        <label>
                            <span>Адрес SIP-сервера <span class="dirty-mark">@DirtyMark("SipServer1")</span></span>
                            <input type="text" @bind="_sipServer1" />
                        </label>
                        <label>
                            <span>Порт <span class="dirty-mark">@DirtyMark("SipPort1")</span></span>
                            <input type="number" @bind="_sipPort1" />
                        </label>
                        <label>
                            <span>Transport <span class="dirty-mark">@DirtyMark("Transport1")</span></span>
                            <select @bind="_transport1">
                                <option>UDP</option>
                                <option>TCP</option>
                            </select>
                        </label>
                        <label>
                            <span>Таймаут сервера <span class="dirty-mark">@DirtyMark("ServerTimeout1")</span></span>
                            <input type="number" @bind="_serverTimeout1" />
                        </label>
                        <label>
                            <span>Количество запросов <span class="dirty-mark">@DirtyMark("RetryCount1")</span></span>
                            <input type="number" @bind="_retryCount1" />
                        </label>
                    </div>
                </section>

                <section class="form-panel">
                    <h3>SIP-сервер 2</h3>
                    <div class="form-grid">
                        <label>
                            <span>Адрес SIP-сервера <span class="dirty-mark">@DirtyMark("SipServer2")</span></span>
                            <input type="text" @bind="_sipServer2" />
                        </label>
                        <label>
                            <span>Порт <span class="dirty-mark">@DirtyMark("SipPort2")</span></span>
                            <input type="number" @bind="_sipPort2" />
                        </label>
                        <label>
                            <span>Transport <span class="dirty-mark">@DirtyMark("Transport2")</span></span>
                            <select @bind="_transport2">
                                <option>UDP</option>
                                <option>TCP</option>
                            </select>
                        </label>
                        <label>
                            <span>Таймаут сервера <span class="dirty-mark">@DirtyMark("ServerTimeout2")</span></span>
                            <input type="number" @bind="_serverTimeout2" />
                        </label>
                        <label>
                            <span>Количество запросов <span class="dirty-mark">@DirtyMark("RetryCount2")</span></span>
                            <input type="number" @bind="_retryCount2" />
                        </label>
                    </div>
                </section>
            </div>

            <section class="cfg-panel">
                <div>
                    <h3>Конфигурационный файл .cfg</h3>
                    <p>Можно импортировать уже подготовленный файл или позже экспортировать собранные настройки.</p>
                </div>

                <div class="cfg-actions">
                    <button class="btn" @onclick="ExportConfig" disabled="@(_exportingConfig || !Credentials.IsAdminConfigured)">
                        @(_exportingConfig ? "Экспорт..." : "Экспорт")
                    </button>
                    <div class="selected-file export-path">@DisplayValue(_lastExportPath)</div>
                </div>

                <div class="cfg-actions">
                    <div class="selected-file">@(_selectedCfgFile?.Name ?? "Файл не выбран")</div>
                    <InputFile OnChange="OnCfgFileSelected" />
                    <button class="btn primary" @onclick="ImportConfig" disabled="@(_selectedCfgFile == null || _importingConfig || !Credentials.IsAdminConfigured)">
                        @(_importingConfig ? "Импорт..." : "Импорт")
                    </button>
                    <button class="btn ghost" @onclick="CancelImport" disabled="@(_selectedCfgFile == null)">Отмена</button>
                </div>

                @if (!string.IsNullOrEmpty(_configMessage))
                {
                    <div class="alert alert-info">@_configMessage</div>
                }
            </section>
        </section>
    }
}

@code {
    [Parameter] public string Ip { get; set; } = string.Empty;

    private PhoneInfo? _phone;
    private string _activeTab = "status";

    private bool _loadingStatus;
    private string? _statusError;
    private string _rawHtmlPreview = string.Empty;

    private bool _lineEnabled = true;
    private string _lineLabel = string.Empty;
    private string _displayName = string.Empty;
    private string _registerName = string.Empty;
    private string _userName = string.Empty;
    private string _password = string.Empty;
    private string _sipServer1 = "10.6.10.10";
    private int _sipPort1 = 5060;
    private string _transport1 = "UDP";
    private int _serverTimeout1 = 3600;
    private int _retryCount1 = 3;
    private string _sipServer2 = string.Empty;
    private int _sipPort2 = 5060;
    private string _transport2 = "UDP";
    private int _serverTimeout2 = 3600;
    private int _retryCount2 = 3;

    private IBrowserFile? _selectedCfgFile;
    private bool _importingConfig;
    private bool _exportingConfig;
    private bool _savingConfig;
    private bool _loadingAccountConfig;
    private string _configMessage = string.Empty;
    private string _lastExportPath = string.Empty;
    private Dictionary<string, string> _loadedConfigValues = new(StringComparer.OrdinalIgnoreCase);

    private static readonly IReadOnlyDictionary<string, string> ConfigToCfgKey = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
    {
        ["LineEnabled"] = "account.1.enable",
        ["LineLabel"] = "account.1.label",
        ["DisplayName"] = "account.1.display_name",
        ["RegisterName"] = "account.1.auth_name",
        ["UserName"] = "account.1.user_name",
        ["Password"] = "account.1.password",
        ["SipServer1"] = "account.1.sip_server.1.address",
        ["SipPort1"] = "account.1.sip_server.1.port",
        ["Transport1"] = "account.1.sip_server.1.transport_type",
        ["ServerTimeout1"] = "account.1.sip_server.1.expires",
        ["RetryCount1"] = "account.1.sip_server.1.retry_counts",
        ["SipServer2"] = "account.1.sip_server.2.address",
        ["SipPort2"] = "account.1.sip_server.2.port",
        ["Transport2"] = "account.1.sip_server.2.transport_type",
        ["ServerTimeout2"] = "account.1.sip_server.2.expires",
        ["RetryCount2"] = "account.1.sip_server.2.retry_counts"
    };

    private IEnumerable<StatusSection> StatusSections => new[]
    {
        new StatusSection("Версия", new[]
        {
            Row("Версия ПО", "Firmware Version", "FirmwareVersion", "Версия ПО"),
            Row("Сборка", "Build Version", "Build", "Сборка")
        }),
        new StatusSection("IPv4", new[]
        {
            Row("Режим порта Internet", "WAN Port Type", "Internet Port Type", "Режим порта Internet"),
            Row("IP-адрес порта Internet", "IPv4 WAN IP Address", "WAN IP Address", "IP Address", "IP-адрес порта Internet"),
            Row("Маска подсети", "Subnet Mask", "Маска подсети"),
            Row("Шлюз", "IPv4 Gateway", "Gateway", "Шлюз"),
            Row("Основной DNS", "IPv4 Primary DNS", "Primary DNS", "Основной DNS", "Осн. DNS-сервер"),
            Row("Дополнительный DNS", "IPv4 Secondary DNS", "Secondary DNS", "Дополнительный DNS")
        }),
        new StatusSection("Общие", new[]
        {
            Row("MAC-адрес", "MAC Address", "MACAddress", "MAC-адрес"),
            Row("ID устройства", "Device ID", "Machine ID", "ID устройства"),
            Row("VLAN ID", "VLAN ID"),
            Row("Статус WAN-порта", "WAN Port Status", "Статус WAN-порта"),
            Row("PC Port статус", "PC Port Status", "PC Port статус"),
            Row("Тип устройства", "Phone Type", "Device Type", "Тип устройства"),
            Row("Время работы", "Uptime", "Время работы"),
            Row("Текущее время", "Current Time", "Текущее время")
        }),
        new StatusSection("Регистрация", new[]
        {
            Row("Аккаунт 1", "Account 1", "Account", "Аккаунт 1", "Аккаунт")
        })
    };

    protected override void OnInitialized()
    {
        _phone = Store.GetByIp(Ip);
        SeedConfigFromPhone();
    }

    private void SeedConfigFromPhone()
    {
        if (_phone == null) return;

        if (_phone.ConfigFields is { Count: > 0 } cachedConfig)
        {
            ApplyStoredConfig(cachedConfig);
            _loadedConfigValues = CurrentConfigValues();
            return;
        }

        var account = ExtractAccount(_phone.Account);
        _lineLabel = account;
        _displayName = account;
        _registerName = account;
        _userName = account;
        ApplyStatusToConfigDefaults();
        _loadedConfigValues = CurrentConfigValues();
    }

    private async Task LoadStatusFromWeb()
    {
        if (_phone == null) return;

        var creds = Credentials.GetAdminCredentials();
        if (creds == null)
        {
            _statusError = "Требуется admin-авторизация.";
            return;
        }

        _loadingStatus = true;
        _statusError = null;
        _rawHtmlPreview = string.Empty;
        await InvokeAsync(StateHasChanged);

        try
        {
            var result = await StatusClient.GetStatusAsync(_phone.IpAddress, creds.Value.username, creds.Value.password);
            _phone.StatusFields = result.Fields;

            var betterModel = ModelResolver.ResolveFromStatus(result.Fields);
            if (!string.IsNullOrWhiteSpace(betterModel))
            {
                _phone.Model = betterModel;
            }

            if (_phone.MacAddress == "unknown" && TryValue(out var mac, "MAC Address", "MAC-адрес"))
                _phone.MacAddress = mac;

            if (string.IsNullOrWhiteSpace(_phone.SerialNumber) && TryValue(out var serial, "Device ID", "Machine ID", "ID устройства"))
                _phone.SerialNumber = serial;

            ApplyStatusToConfigDefaults();
            Store.Upsert(_phone);
            _statusError = null;
            _rawHtmlPreview = result.RawHtml[..Math.Min(2000, result.RawHtml.Length)];
        }
        catch (Exception ex)
        {
            _statusError = $"Ошибка загрузки статуса: {GetUsefulErrorMessage(ex)}";
        }

        _loadingStatus = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadStatusSmart()
    {
        if (_phone == null) return;

        var creds = Credentials.GetAdminCredentials();
        if (creds == null)
        {
            _statusError = "Требуется admin-авторизация.";
            return;
        }

        _loadingStatus = true;
        _statusError = null;
        _rawHtmlPreview = string.Empty;
        await InvokeAsync(StateHasChanged);

        try
        {
            if (ShouldUseModernStatusClient())
            {
                var modernStatus = await ModernApiClient.GetStatusAsync(_phone.IpAddress, creds.Value.username, creds.Value.password);
                ApplyModernStatus(modernStatus);
                _rawHtmlPreview = string.Join(Environment.NewLine, modernStatus.RawValues.Take(80).Select(x => $"{x.Key}: {x.Value}"));
            }
            else
            {
                var result = await StatusClient.GetStatusAsync(_phone.IpAddress, creds.Value.username, creds.Value.password);
                _phone.StatusFields = result.Fields;

                var betterModel = ModelResolver.ResolveFromStatus(result.Fields);
                if (!string.IsNullOrWhiteSpace(betterModel))
                    _phone.Model = betterModel;

                if (_phone.MacAddress == "unknown" && TryValue(out var mac, "MAC Address", "MAC-адрес"))
                    _phone.MacAddress = mac;

                if (string.IsNullOrWhiteSpace(_phone.SerialNumber) && TryValue(out var serial, "Device ID", "Machine ID", "ID устройства"))
                    _phone.SerialNumber = serial;

                _rawHtmlPreview = result.RawHtml[..Math.Min(2000, result.RawHtml.Length)];
            }

            ApplyStatusToConfigDefaults();
            Store.Upsert(_phone);
            _statusError = null;
        }
        catch (Exception ex)
        {
            _statusError = $"Ошибка загрузки статуса: {GetUsefulErrorMessage(ex)}";
        }

        _loadingStatus = false;
        await InvokeAsync(StateHasChanged);
    }

    private bool ShouldUseModernStatusClient()
    {
        if (_phone == null)
            return false;

        var firmware = TryValue(out var cachedFirmware, "Firmware Version", "FirmwareVersion", "Firmware")
            ? cachedFirmware
            : null;

        var family = ModelResolver.ResolveFamily(_phone.Model, firmware);
        return family is YealinkPhoneFamily.ModernApi or YealinkPhoneFamily.WSeries || UsesModernHttps(_phone.Model);
    }

    private void ApplyModernStatus(PhoneStatus status)
    {
        if (_phone == null)
            return;

        var fields = new Dictionary<string, string>(status.RawValues, StringComparer.OrdinalIgnoreCase);
        var resolvedModel = ModelResolver.Resolve(status.FirmwareVersion, status.HardwareVersion);

        AddField(fields, "Firmware Version", status.FirmwareVersion);
        AddField(fields, "FirmwareVersion", status.FirmwareVersion);
        AddField(fields, "Build Version", status.HardwareVersion);
        AddField(fields, "Build", status.HardwareVersion);
        AddField(fields, "Model", status.Model ?? resolvedModel);
        AddField(fields, "MAC Address", status.MacAddress);
        AddField(fields, "MACAddress", status.MacAddress);
        AddField(fields, "Device ID", status.DeviceId);
        AddField(fields, "Machine ID", status.DeviceId);
        AddField(fields, "WAN Port Type", status.NetworkMode);
        AddField(fields, "Internet Port Type", status.NetworkMode);
        AddField(fields, "IPv4 WAN IP Address", status.IpAddressV4);
        AddField(fields, "WAN IP Address", status.IpAddressV4);
        AddField(fields, "IP Address", status.IpAddressV4);
        AddField(fields, "Subnet Mask", status.SubnetMask);
        AddField(fields, "IPv4 Gateway", status.Gateway);
        AddField(fields, "Gateway", status.Gateway);
        AddField(fields, "IPv4 Primary DNS", status.PrimaryDns);
        AddField(fields, "Primary DNS", status.PrimaryDns);
        AddField(fields, "IPv4 Secondary DNS", status.SecondaryDns);
        AddField(fields, "Secondary DNS", status.SecondaryDns);
        AddField(fields, "VLAN ID", status.VlanId);
        AddField(fields, "WAN Port Status", status.WanPortStatus);
        AddField(fields, "PC Port Status", status.PcPortStatus);
        AddField(fields, "Device Type", status.DeviceType);
        AddField(fields, "Current Time", status.CurrentTime);
        AddField(fields, "Uptime", FormatUptime(status.Uptime));

        var firstAccount = status.Accounts.OrderBy(x => x.Line).FirstOrDefault();
        if (firstAccount != null)
        {
            var accountText = FormatAccount(firstAccount);
            AddField(fields, "Account 1", accountText);
            AddField(fields, "Account", firstAccount.Number ?? accountText);
            _phone.Account = firstAccount.Number ?? _phone.Account;
        }

        _phone.StatusFields = fields;
        _phone.IsOnline = true;
        _phone.LastSeen = DateTime.Now;

        if (!string.IsNullOrWhiteSpace(status.Model ?? resolvedModel))
            _phone.Model = status.Model ?? resolvedModel;

        if (!string.IsNullOrWhiteSpace(status.MacAddress))
            _phone.MacAddress = status.MacAddress;

        if (!string.IsNullOrWhiteSpace(status.DeviceId))
            _phone.SerialNumber = status.DeviceId;
    }

    private static void AddField(Dictionary<string, string> fields, string key, string? value)
    {
        if (!string.IsNullOrWhiteSpace(value))
            fields[key] = value;
    }

    private static string FormatAccount(AccountStatus account)
    {
        var number = account.Number ?? account.Label ?? $"Account {account.Line}";
        if (!string.IsNullOrWhiteSpace(account.Server) && !number.Contains('@'))
            number = $"{number}@{account.Server}";

        return string.IsNullOrWhiteSpace(account.Status)
            ? number
            : $"{number} : {account.Status}";
    }

    private static string? FormatUptime(int? totalSeconds)
    {
        if (!totalSeconds.HasValue)
            return null;

        var time = TimeSpan.FromSeconds(totalSeconds.Value);
        return time.Days > 0
            ? $"{time.Days} дни {time.Hours:00}:{time.Minutes:00}"
            : $"{(int)time.TotalHours:00}:{time.Minutes:00}";
    }

    private static string GetUsefulErrorMessage(Exception ex)
    {
        var messages = new List<string>();
        for (var current = ex; current != null; current = current.InnerException)
        {
            if (!string.IsNullOrWhiteSpace(current.Message) && !messages.Contains(current.Message))
                messages.Add(current.Message);
        }

        return string.Join(" / ", messages);
    }

    private void ApplyStatusToConfigDefaults()
    {
        if ((_phone?.ConfigFields?.Count ?? 0) > 0)
            return;

        if (_phone?.StatusFields is { Count: > 0 } fields)
        {
            var label = ValueFrom(fields, string.Empty, "account.info.1.label", "account.info.0.label", "data.1.label", "data.0.label");
            var displayName = ValueFrom(fields, string.Empty, "account.info.1.displayName", "account.info.0.displayName", "data.1.displayName", "data.0.displayName");
            var registerName = ValueFrom(fields, string.Empty, "account.info.1.registerName", "account.info.0.registerName", "data.1.registerName", "data.0.registerName");
            var userName = ValueFrom(fields, string.Empty, "account.info.1.userName", "account.info.0.userName", "data.1.userName", "data.0.userName");
            var sipServer = ValueFrom(fields, string.Empty, "account.info.1.sipServer", "account.info.0.sipServer", "data.1.sipServer", "data.0.sipServer");

            if (!string.IsNullOrWhiteSpace(label))
                _lineLabel = label;

            if (!string.IsNullOrWhiteSpace(displayName))
                _displayName = displayName;

            if (!string.IsNullOrWhiteSpace(registerName))
                _registerName = registerName;

            if (!string.IsNullOrWhiteSpace(userName))
                _userName = userName;

            if (!string.IsNullOrWhiteSpace(sipServer))
                _sipServer1 = sipServer;
        }

        if (TryValue(out var account, "Account 1", "Account", "Аккаунт 1", "Аккаунт"))
        {
            var extension = ExtractAccount(account);
            if (!string.IsNullOrWhiteSpace(extension))
            {
                if (string.IsNullOrWhiteSpace(_lineLabel))
                    _lineLabel = extension;

                if (string.IsNullOrWhiteSpace(_displayName))
                    _displayName = extension;

                if (string.IsNullOrWhiteSpace(_registerName))
                    _registerName = extension;

                if (string.IsNullOrWhiteSpace(_userName))
                    _userName = extension;
            }
        }
    }

    private async Task LoadAccountConfigFromWeb()
    {
        if (_phone == null) return;

        var creds = Credentials.GetAdminCredentials();
        if (creds == null)
        {
            _configMessage = "Требуется admin-авторизация для загрузки конфигурации.";
            return;
        }

        _loadingAccountConfig = true;
        _configMessage = "Загрузка параметров аккаунта...";
        await InvokeAsync(StateHasChanged);

        try
        {
            var fields = IsModernConfigPhone()
                ? (await ModernApiClient.GetAccountConfigAsync(_phone.IpAddress, creds.Value.username, creds.Value.password)).Fields
                : await LoadLegacyAccountConfigFields(creds.Value.username, creds.Value.password);

            await MergeStatusFieldsForConfig(fields, creds.Value.username, creds.Value.password);
            ApplyAccountConfig(fields);
            SaveCurrentConfigToPhoneCache();
            Store.Upsert(_phone);
            await Store.SaveAsync();
            _configMessage = "Параметры аккаунта загружены из телефона. Пароль не подставляю в форму из соображений безопасности.";
        }
        catch (Exception ex)
        {
            _configMessage = $"Ошибка загрузки конфигурации аккаунта: {ex.Message}";
        }
        finally
        {
            _loadingAccountConfig = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void ApplyAccountConfig(Dictionary<string, string> fields)
    {
        _lineEnabled = BoolValue(fields, true, "AccountEnable.1", "data.formData.AccountEnable.1", "account.1.enable");
        _lineLabel = ValueFrom(fields, _lineLabel, "AccountLabel.1", "data.formData.AccountLabel.1", "account.1.label", "account.info.1.label", "account.info.0.label", "data.1.label", "data.0.label");
        _displayName = ValueFrom(fields, _displayName, "AccountDisplayName.1", "data.formData.AccountDisplayName.1", "account.1.display_name", "account.info.1.displayName", "account.info.0.displayName", "data.1.displayName", "data.0.displayName");
        _registerName = ValueFrom(fields, _registerName, "AccountRegisterName.1", "data.formData.AccountRegisterName.1", "account.1.auth_name", "account.info.1.registerName", "account.info.0.registerName", "data.1.registerName", "data.0.registerName");
        _userName = ValueFrom(fields, _userName, "AccountUserName.1", "data.formData.AccountUserName.1", "account.1.user_name", "account.info.1.userName", "account.info.0.userName", "data.1.userName", "data.0.userName");

        _sipServer1 = ValueFrom(fields, _sipServer1, "AccountServerAddr1.1", "data.formData.AccountServerAddr1.1", "AccountServerAddr.1.1", "data.formData.AccountServerAddr.1.1", "account.1.sip_server.1.address", "account.info.1.sipServer", "account.info.0.sipServer", "data.1.sipServer", "data.0.sipServer");
        _sipPort1 = IntValue(fields, _sipPort1, "AccountServerPort1.1", "data.formData.AccountServerPort1.1", "AccountServerPort.1.1", "data.formData.AccountServerPort.1.1");
        _transport1 = TransportValue(fields, _transport1, "AccountServerTransport1.1", "data.formData.AccountServerTransport1.1", "AccountServerTransport.1.1", "data.formData.AccountServerTransport.1.1");
        _serverTimeout1 = IntValue(fields, _serverTimeout1, "AccountServerExpires1.1", "data.formData.AccountServerExpires1.1", "AccountServerExpires.1.1", "data.formData.AccountServerExpires.1.1", "account.1.sip_server.1.expires");
        _retryCount1 = IntValue(fields, _retryCount1, "AccountServerRetryCounts1.1", "data.formData.AccountServerRetryCounts1.1", "AccountServerRetryCounts.1.1", "data.formData.AccountServerRetryCounts.1.1", "account.1.sip_server.1.retry_counts");

        _sipServer2 = ValueFrom(fields, _sipServer2, "AccountServerAddr2.1", "data.formData.AccountServerAddr2.1", "AccountServerAddr.1.2", "data.formData.AccountServerAddr.1.2", "account.1.sip_server.2.address");
        _sipPort2 = IntValue(fields, _sipPort2, "AccountServerPort2.1", "data.formData.AccountServerPort2.1", "AccountServerPort.1.2", "data.formData.AccountServerPort.1.2");
        _transport2 = TransportValue(fields, _transport2, "AccountServerTransport2.1", "data.formData.AccountServerTransport2.1", "AccountServerTransport.1.2", "data.formData.AccountServerTransport.1.2");
        _serverTimeout2 = IntValue(fields, _serverTimeout2, "AccountServerExpires2.1", "data.formData.AccountServerExpires2.1", "AccountServerExpires.1.2", "data.formData.AccountServerExpires.1.2", "account.1.sip_server.2.expires");
        _retryCount2 = IntValue(fields, _retryCount2, "AccountServerRetryCounts2.1", "data.formData.AccountServerRetryCounts2.1", "AccountServerRetryCounts.1.2", "data.formData.AccountServerRetryCounts.1.2", "account.1.sip_server.2.retry_counts");

        _password = string.Empty;
        _loadedConfigValues = CurrentConfigValues();
    }

    private async Task MergeStatusFieldsForConfig(Dictionary<string, string> fields, string username, string password)
    {
        if (_phone == null)
            return;

        try
        {
            if (IsModernConfigPhone())
            {
                var modernStatus = await ModernApiClient.GetStatusAsync(_phone.IpAddress, username, password);
                ApplyModernStatus(modernStatus);
            }
            else
            {
                var status = await StatusClient.GetStatusAsync(_phone.IpAddress, username, password);
                _phone.StatusFields = status.Fields;
            }

            if (_phone.StatusFields is { Count: > 0 } statusFields)
            {
                foreach (var item in statusFields)
                {
                    if (!fields.ContainsKey(item.Key) ||
                        item.Key.Equals("Account", StringComparison.OrdinalIgnoreCase) ||
                        item.Key.Equals("Account 1", StringComparison.OrdinalIgnoreCase))
                    {
                        fields[item.Key] = item.Value;
                    }
                }
            }
        }
        catch
        {
            // Status data is optional for config editing.
        }
    }

    private async Task<Dictionary<string, string>> LoadLegacyAccountConfigFields(string username, string password)
    {
        if (_phone == null)
            return new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);

        var fields = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);

        try
        {
            var result = await StatusClient.GetAccountConfigAsync(_phone.IpAddress, username, password);
            foreach (var item in result.Fields)
                fields[item.Key] = item.Value;
        }
        catch
        {
            // Old T3x phones do not always expose account edit fields through the JSON API.
        }

        var cfgBytes = await ConfigManager.DownloadConfigAsync(_phone.IpAddress, username, password);
        var cfgText = System.Text.Encoding.UTF8.GetString(cfgBytes);
        foreach (var item in ParseCfgFields(cfgText))
            fields[item.Key] = item.Value;

        return fields;
    }

    private static Dictionary<string, string> ParseCfgFields(string cfgText)
    {
        var fields = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);

        foreach (var rawLine in cfgText.Split('\n'))
        {
            var line = rawLine.Trim();
            if (string.IsNullOrWhiteSpace(line) || line.StartsWith('#') || !line.Contains('='))
                continue;

            var parts = line.Split('=', 2);
            var key = parts[0].Trim();
            var value = parts.Length > 1 ? parts[1].Trim() : string.Empty;

            if (!string.IsNullOrWhiteSpace(key))
                fields[key] = value;
        }

        return fields;
    }

    private async Task SaveConfig()
    {
        if (_phone == null) return;

        var creds = Credentials.GetAdminCredentials();
        if (creds == null)
        {
            _configMessage = "Требуется admin-авторизация для сохранения конфигурации.";
            return;
        }

        var changes = BuildChangedCfgValues();
        if (changes.Count == 0)
        {
            _configMessage = "Изменений нет.";
            return;
        }

        _savingConfig = true;
        _configMessage = "Формирование и отправка delta .cfg...";
        await InvokeAsync(StateHasChanged);

        try
        {
            var generatedPath = await SaveDeltaCfgAsync(changes);
            OperationResult result;

            if (IsModernConfigPhone())
            {
                result = await ModernApiClient.ImportCfgAsync(_phone.IpAddress, creds.Value.username, creds.Value.password, generatedPath);
            }
            else
            {
                var upload = await ConfigManager.UploadConfigAsync(_phone.IpAddress, creds.Value.username, creds.Value.password, generatedPath);
                result = upload.Success
                    ? OperationResult.Ok($"CFG import выполнен. Тип: {upload.Filetype}, код: {upload.ResultCode}")
                    : OperationResult.Fail("CFG import завершился без подтверждения успеха.", upload.RawResponse);
            }

            if (result.Success)
            {
                _phone.Account = _lineLabel;
                SaveCurrentConfigToPhoneCache();
                Store.Upsert(_phone);
                await Store.SaveAsync();
                _loadedConfigValues = CurrentConfigValues();
                _configMessage = $"Изменения отправлены в телефон. Delta .cfg: {generatedPath}";
            }
            else
            {
                _configMessage = $"Ошибка сохранения: {result.Message}";
            }
        }
        catch (Exception ex)
        {
            _configMessage = $"Ошибка сохранения: {GetUsefulErrorMessage(ex)}";
        }
        finally
        {
            _savingConfig = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task ExportConfig()
    {
        if (_phone == null) return;

        var creds = Credentials.GetAdminCredentials();
        if (creds == null)
        {
            _configMessage = "Требуется admin-авторизация для export CFG.";
            return;
        }

        _exportingConfig = true;
        _configMessage = "Экспорт конфигурационного файла...";
        await InvokeAsync(StateHasChanged);

        try
        {
            var result = IsModernConfigPhone()
                ? await ModernApiClient.ExportCfgAsync(_phone.IpAddress, creds.Value.username, creds.Value.password, "all")
                : await ConfigManager.ExportCfgAsync(_phone.IpAddress, creds.Value.username, creds.Value.password, "all");

            if (result.Success)
            {
                _lastExportPath = result.FilePath ?? string.Empty;
                _configMessage = $"CFG сохранен: {_lastExportPath}";
            }
            else
            {
                _configMessage = $"Ошибка export CFG: {result.Message}";
            }
        }
        catch (Exception ex)
        {
            _configMessage = $"Ошибка export CFG: {GetUsefulErrorMessage(ex)}";
        }
        finally
        {
            _exportingConfig = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void OnCfgFileSelected(InputFileChangeEventArgs e)
    {
        _selectedCfgFile = e.File;
        _configMessage = _selectedCfgFile == null
            ? string.Empty
            : $"Выбран файл: {_selectedCfgFile.Name}";
    }

    private async Task ImportConfig()
    {
        if (_phone == null || _selectedCfgFile == null) return;

        var creds = Credentials.GetAdminCredentials();
        if (creds == null)
        {
            _configMessage = "Требуется admin-авторизация для импорта.";
            return;
        }

        _importingConfig = true;
        _configMessage = "Импорт конфигурационного файла...";

        var tempPath = Path.Combine(Path.GetTempPath(), $"{Guid.NewGuid():N}_{_selectedCfgFile.Name}");
        try
        {
            await using (var input = _selectedCfgFile.OpenReadStream(maxAllowedSize: 2 * 1024 * 1024))
            await using (var output = File.Create(tempPath))
            {
                await input.CopyToAsync(output);
            }

            if (IsModernConfigPhone())
            {
                var result = await ModernApiClient.ImportCfgAsync(_phone.IpAddress, creds.Value.username, creds.Value.password, tempPath);
                _configMessage = result.Success
                    ? "Импорт выполнен."
                    : $"Импорт завершился с ошибкой: {result.Message}";
            }
            else
            {
                var result = await ConfigManager.UploadConfigAsync(
                    _phone.IpAddress,
                    creds.Value.username,
                    creds.Value.password,
                    tempPath);

                _configMessage = result.Success
                    ? $"Импорт выполнен. Тип: {result.Filetype}, код: {result.ResultCode}"
                    : "Импорт завершился без подтверждения успеха.";
            }
        }
        catch (Exception ex)
        {
            _configMessage = $"Ошибка импорта: {ex.Message}";
        }
        finally
        {
            _importingConfig = false;
            if (File.Exists(tempPath))
                File.Delete(tempPath);
        }
    }

    private void CancelImport()
    {
        _selectedCfgFile = null;
        _configMessage = string.Empty;
    }

    private void SaveCurrentConfigToPhoneCache()
    {
        if (_phone == null)
            return;

        var values = CurrentConfigValues();
        values.Remove("Password");
        _phone.ConfigFields = values;
    }

    private void ApplyStoredConfig(Dictionary<string, string> values)
    {
        _lineEnabled = BoolValue(values, _lineEnabled, "LineEnabled");
        _lineLabel = ValueFrom(values, _lineLabel, "LineLabel");
        _displayName = ValueFrom(values, _displayName, "DisplayName");
        _registerName = ValueFrom(values, _registerName, "RegisterName");
        _userName = ValueFrom(values, _userName, "UserName");
        _password = string.Empty;

        _sipServer1 = ValueFrom(values, _sipServer1, "SipServer1");
        _sipPort1 = IntValue(values, _sipPort1, "SipPort1");
        _transport1 = StoredTransportValue(values, _transport1, "Transport1");
        _serverTimeout1 = IntValue(values, _serverTimeout1, "ServerTimeout1");
        _retryCount1 = IntValue(values, _retryCount1, "RetryCount1");

        _sipServer2 = ValueFrom(values, _sipServer2, "SipServer2");
        _sipPort2 = IntValue(values, _sipPort2, "SipPort2");
        _transport2 = StoredTransportValue(values, _transport2, "Transport2");
        _serverTimeout2 = IntValue(values, _serverTimeout2, "ServerTimeout2");
        _retryCount2 = IntValue(values, _retryCount2, "RetryCount2");
    }

    private string DirtyMark(string key) => IsConfigChanged(key) ? "*" : string.Empty;

    private bool IsConfigChanged(string key)
    {
        if (_loadedConfigValues.Count == 0)
            return false;

        var current = CurrentConfigValues();
        return current.TryGetValue(key, out var currentValue) &&
               _loadedConfigValues.TryGetValue(key, out var loadedValue) &&
               !string.Equals(currentValue, loadedValue, StringComparison.Ordinal);
    }

    private Dictionary<string, string> CurrentConfigValues() => new(StringComparer.OrdinalIgnoreCase)
    {
        ["LineEnabled"] = _lineEnabled ? "1" : "0",
        ["LineLabel"] = NormalizeCfgValue(_lineLabel),
        ["DisplayName"] = NormalizeCfgValue(_displayName),
        ["RegisterName"] = NormalizeCfgValue(_registerName),
        ["UserName"] = NormalizeCfgValue(_userName),
        ["Password"] = NormalizeCfgValue(_password),
        ["SipServer1"] = NormalizeCfgValue(_sipServer1),
        ["SipPort1"] = _sipPort1.ToString(),
        ["Transport1"] = TransportToCfgValue(_transport1),
        ["ServerTimeout1"] = _serverTimeout1.ToString(),
        ["RetryCount1"] = _retryCount1.ToString(),
        ["SipServer2"] = NormalizeCfgValue(_sipServer2),
        ["SipPort2"] = _sipPort2.ToString(),
        ["Transport2"] = TransportToCfgValue(_transport2),
        ["ServerTimeout2"] = _serverTimeout2.ToString(),
        ["RetryCount2"] = _retryCount2.ToString()
    };

    private Dictionary<string, string> BuildChangedCfgValues()
    {
        var current = CurrentConfigValues();
        var changes = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);

        foreach (var (key, cfgKey) in ConfigToCfgKey)
        {
            if (!current.TryGetValue(key, out var value))
                continue;

            if (key.Equals("Password", StringComparison.OrdinalIgnoreCase) && string.IsNullOrWhiteSpace(value))
                continue;

            if (!_loadedConfigValues.TryGetValue(key, out var loadedValue) ||
                !string.Equals(value, loadedValue, StringComparison.Ordinal))
            {
                changes[cfgKey] = value;
            }
        }

        return changes;
    }

    private async Task<string> SaveDeltaCfgAsync(Dictionary<string, string> changes)
    {
        if (_phone == null)
            throw new InvalidOperationException("Phone is not loaded.");

        var dir = Path.Combine(AppContext.BaseDirectory, "generated", SafePathSegment(_phone.IpAddress));
        Directory.CreateDirectory(dir);

        var path = Path.Combine(dir, $"account-delta-{DateTime.Now:yyyyMMdd-HHmmss}.cfg");
        var lines = new List<string> { "#!version:1.0.0.1", string.Empty };
        lines.AddRange(changes.Select(x => $"{x.Key} = {x.Value}"));

        await File.WriteAllTextAsync(path, string.Join(Environment.NewLine, lines), System.Text.Encoding.UTF8);
        return path;
    }

    private bool IsModernConfigPhone()
    {
        if (_phone == null)
            return false;

        var firmware = TryValue(out var cachedFirmware, "Firmware Version", "FirmwareVersion", "Firmware")
            ? cachedFirmware
            : null;

        var family = ModelResolver.ResolveFamily(_phone.Model, firmware);
        return family is YealinkPhoneFamily.ModernApi or YealinkPhoneFamily.WSeries || UsesModernHttps(_phone.Model);
    }

    private static string NormalizeCfgValue(string? value) =>
        (value ?? string.Empty).Replace("\r", " ").Replace("\n", " ").Trim();

    private static string TransportToCfgValue(string? transport) =>
        transport?.ToUpperInvariant() switch
        {
            "TCP" => "1",
            "TLS" => "2",
            _ => "0"
        };

    private static string StoredTransportValue(Dictionary<string, string> fields, string fallback, params string[] keys)
    {
        var value = ValueFrom(fields, string.Empty, keys);
        return value switch
        {
            "0" => "UDP",
            "1" => "TCP",
            "2" => "TLS",
            "" => fallback,
            _ => value.Equals("TCP", StringComparison.OrdinalIgnoreCase) ? "TCP" : "UDP"
        };
    }

    private static string SafePathSegment(string value)
    {
        var filename = value.Replace(':', '_').Replace('/', '_').Replace('\\', '_');
        foreach (var invalid in Path.GetInvalidFileNameChars())
            filename = filename.Replace(invalid, '_');

        return string.IsNullOrWhiteSpace(filename) ? "phone" : filename;
    }

    private StatusRow Row(string label, params string[] keys) => new(label, Value(keys));

    private string Value(params string[] keys)
    {
        if (TryValue(out var value, keys))
            return value;

        if (_phone != null)
        {
            if (keys.Any(k => k.Equals("MACAddress", StringComparison.OrdinalIgnoreCase)))
                return string.IsNullOrWhiteSpace(_phone.MacAddress) ? "-" : _phone.MacAddress;

            if (keys.Any(k => k.Equals("Account", StringComparison.OrdinalIgnoreCase)))
                return string.IsNullOrWhiteSpace(_phone.Account) ? "-" : _phone.Account;
        }

        return "-";
    }

    private bool TryValue(out string value, params string[] keys)
    {
        value = string.Empty;
        if (_phone?.StatusFields == null) return false;

        foreach (var key in keys)
        {
            if (_phone.StatusFields.TryGetValue(key, out var found) && !string.IsNullOrWhiteSpace(found))
            {
                value = found;
                return true;
            }
        }

        return false;
    }

    private static string ValueFrom(Dictionary<string, string> fields, string fallback, params string[] keys)
    {
        foreach (var key in keys)
        {
            if (fields.TryGetValue(key, out var value) && !string.IsNullOrWhiteSpace(value))
                return value;
        }

        foreach (var key in keys)
        {
            var match = fields.FirstOrDefault(x =>
                x.Key.EndsWith($".{key}", StringComparison.OrdinalIgnoreCase) &&
                !string.IsNullOrWhiteSpace(x.Value));

            if (!string.IsNullOrWhiteSpace(match.Value))
                return match.Value;
        }

        return fallback;
    }

    private static int IntValue(Dictionary<string, string> fields, int fallback, params string[] keys)
    {
        var value = ValueFrom(fields, string.Empty, keys);
        return int.TryParse(value, out var parsed) ? parsed : fallback;
    }

    private static bool BoolValue(Dictionary<string, string> fields, bool fallback, params string[] keys)
    {
        var value = ValueFrom(fields, string.Empty, keys);
        return value switch
        {
            "1" => true,
            "true" => true,
            "0" => false,
            "false" => false,
            _ => fallback
        };
    }

    private static string TransportValue(Dictionary<string, string> fields, string fallback, params string[] keys)
    {
        var value = ValueFrom(fields, string.Empty, keys);
        return value switch
        {
            "0" => "UDP",
            "1" => "TCP",
            "2" => "TLS",
            "" => fallback,
            _ => value.Equals("TCP", StringComparison.OrdinalIgnoreCase) ? "TCP" : "UDP"
        };
    }

    private static string ExtractAccount(string value)
    {
        if (string.IsNullOrWhiteSpace(value) || value.Equals("none", StringComparison.OrdinalIgnoreCase))
            return string.Empty;

        var first = value.Split(',', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries).FirstOrDefault() ?? value;
        first = first.Split(':', StringSplitOptions.TrimEntries).FirstOrDefault() ?? first;
        first = first.Split('@', StringSplitOptions.TrimEntries).FirstOrDefault() ?? first;
        return first.Trim();
    }

    private static string DisplayValue(string? value) =>
        string.IsNullOrWhiteSpace(value) || value.Equals("unknown", StringComparison.OrdinalIgnoreCase)
            ? "-"
            : value;

    private void OpenWebInterface()
    {
        if (_phone != null)
        {
            var scheme = UsesModernHttps(_phone.Model) ? "https" : "http";
            Navigation.NavigateTo($"{scheme}://{_phone.IpAddress}", forceLoad: true);
        }
    }

    private static bool UsesModernHttps(string? model) =>
        !string.IsNullOrWhiteSpace(model) &&
        (model.Contains("T4", StringComparison.OrdinalIgnoreCase) ||
         model.Contains("T5", StringComparison.OrdinalIgnoreCase) ||
         model.Contains("W70", StringComparison.OrdinalIgnoreCase));

    private void GoBack() => Navigation.NavigateTo("/");

    private sealed record StatusSection(string Title, IReadOnlyList<StatusRow> Rows);
    private sealed record StatusRow(string Label, string Value);
}
