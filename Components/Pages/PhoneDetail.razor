    private IEnumerable<CallHistoryEntry> FilteredCallHistory
    {
        get
        {
            var query = _callHistorySearch.Trim();
            IEnumerable<CallHistoryEntry> rows = _callHistory;

            if (!string.IsNullOrWhiteSpace(query))
                rows = rows.Where(call => MatchesCallHistorySearch(call, query));

            return _callHistorySortColumn switch
            {
                "type" => SortRows(rows, x => x.Type),
                "local" => SortRows(rows, x => x.LocalName),
                "remote" => SortRows(rows, x => x.RemoteDisplay),
                "number" => SortRows(rows, x => x.RemoteName),
                "server" => SortRows(rows, x => x.RemoteServer),
                "duration" => SortRows(rows, x => ParseCallDuration(x.Duration)),
                _ => SortRows(rows, x => ParseCallDateTime(x.DateTimeText))
            };
        }
    }

    private int CountCalls(string type) =>
        _callHistory.Count(x => x.Type.Equals(type, StringComparison.OrdinalIgnoreCase));

    private void SortCallHistory(string column)
    {
        if (_callHistorySortColumn.Equals(column, StringComparison.OrdinalIgnoreCase))
        {
            _callHistorySortAscending = !_callHistorySortAscending;
            return;
        }

        _callHistorySortColumn = column;
        _callHistorySortAscending = column is not ("datetime" or "duration");
    }

    private string SortIcon(string column)
    {
        if (!_callHistorySortColumn.Equals(column, StringComparison.OrdinalIgnoreCase))
            return string.Empty;

        return _callHistorySortAscending ? "↑" : "↓";
    }

    private string CallTypeClass(string type)
    {
        if (type.Contains("Пропущ", StringComparison.OrdinalIgnoreCase))
            return "missed";

        if (type.Contains("Принят", StringComparison.OrdinalIgnoreCase))
            return "received";

        if (type.Contains("Исход", StringComparison.OrdinalIgnoreCase))
            return "outgoing";

        if (type.Contains("Переад", StringComparison.OrdinalIgnoreCase))
            return "forwarded";

        return "unknown";
    }

    private IEnumerable<CallHistoryEntry> SortRows<TKey>(IEnumerable<CallHistoryEntry> rows, Func<CallHistoryEntry, TKey> keySelector) =>
        _callHistorySortAscending
            ? rows.OrderBy(keySelector)
            : rows.OrderByDescending(keySelector);

    private static bool MatchesCallHistorySearch(CallHistoryEntry call, string query) =>
        Contains(call.Type, query) ||
        Contains(call.DateTimeText, query) ||
        Contains(call.LocalName, query) ||
        Contains(call.LocalServer, query) ||
        Contains(call.RemoteDisplay, query) ||
        Contains(call.RemoteName, query) ||
        Contains(call.RemoteServer, query) ||
        Contains(call.Duration, query);

    private static bool Contains(string? value, string query) =>
        value?.Contains(query, StringComparison.OrdinalIgnoreCase) == true;

    private static DateTime ParseCallDateTime(string? value) =>
        DateTime.TryParseExact(value, "yyyy-MM-dd HH:mm:ss", System.Globalization.CultureInfo.InvariantCulture, System.Globalization.DateTimeStyles.None, out var parsed)
            ? parsed
            : DateTime.MinValue;

    private static TimeSpan ParseCallDuration(string? value) =>
        TimeSpan.TryParse(value, System.Globalization.CultureInfo.InvariantCulture, out var parsed)
            ? parsed
            : TimeSpan.Zero;

    private Dictionary<string, string> CurrentExpansionValues()
    {
        EnsureExpansionKeys();
        var values = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);

        if (_phone == null)
            return values;

        foreach (var key in _phone.ExpansionKeys)
        {
            values[$"{key.Index}.label"] = NormalizeCfgValue(key.Label);
            values[$"{key.Index}.value"] = NormalizeCfgValue(key.Value);
            values[$"{key.Index}.line"] = "0";
            values[$"{key.Index}.type"] = "13";
        }

        return values;
    }

    private void SnapshotExpansionValues()
    {
        _loadedExpansionValues = CurrentExpansionValues();
    }

    private Dictionary<string, string> BuildExpansionChangedCfgValues()
    {
        var current = CurrentExpansionValues();
        var changes = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
        var touchedIndexes = new HashSet<string>(StringComparer.OrdinalIgnoreCase);

        foreach (var item in current)
        {
            if (!_loadedExpansionValues.TryGetValue(item.Key, out var loadedValue) ||
                !string.Equals(item.Value, loadedValue, StringComparison.Ordinal))
            {
                var parts = item.Key.Split('.', 2);
                if (parts.Length == 2)
                {
                    changes[$"expansion_module.1.key.{parts[0]}.{parts[1]}"] = item.Value;
                    touchedIndexes.Add(parts[0]);
                }
            }
        }

        foreach (var index in touchedIndexes)
        {
            changes[$"expansion_module.1.key.{index}.line"] = "0";
            changes[$"expansion_module.1.key.{index}.type"] = "13";
        }

        return changes;
    }

    private async Task<string> SaveExpansionDeltaCfgAsync(Dictionary<string, string> changes)
    {
        if (_phone == null)
            throw new InvalidOperationException("Phone is not loaded.");

        var dir = Path.Combine(AppContext.BaseDirectory, "generated", SafePathSegment(_phone.IpAddress));
        Directory.CreateDirectory(dir);

        var path = Path.Combine(dir, $"expansion-panel-delta-{DateTime.Now:yyyyMMdd-HHmmss}.cfg");
        var lines = new List<string> { "#!version:1.0.0.1", string.Empty };
        lines.AddRange(changes.OrderBy(x => x.Key, StringComparer.OrdinalIgnoreCase).Select(x => $"{x.Key} = {x.Value}"));

        await File.WriteAllTextAsync(path, string.Join(Environment.NewLine, lines), System.Text.Encoding.UTF8);
        return path;
    }

    private bool ShowAccountSelector => IsModernConfigPhone();

    private IEnumerable<int> AccountLineOptions
    {
        get
        {
            if (_phone == null || !IsModernConfigPhone())
                return new[] { 1 };

            var maxLine = Math.Max(6, DetectedMaxAccountLine());
            return Enumerable.Range(1, Math.Clamp(maxLine, 1, 16));
        }
    }

    private int ResolveInitialAccountLine()
    {
        if (_phone == null)
            return 1;

        if (_phone.DefaultAccountLine is > 0)
            return _phone.DefaultAccountLine.Value;

        return _phone.Accounts
            .Where(x => x.Enabled || !string.IsNullOrWhiteSpace(x.Label) || !string.IsNullOrWhiteSpace(x.UserName))
            .OrderBy(x => x.Line)
            .Select(x => x.Line)
            .FirstOrDefault(1);
    }

    private int DetectedMaxAccountLine()
    {
        if (_phone == null)
            return 1;

        var max = _phone.Accounts.Count == 0 ? 1 : _phone.Accounts.Max(x => Math.Max(x.Line, 1));

        foreach (var key in _phone.ConfigFields.Keys.Concat(_phone.StatusFields.Keys))
        {
            var match = System.Text.RegularExpressions.Regex.Match(key, @"(?:Account\w*\.|account\.|Line)(\d+)");
            if (match.Success && int.TryParse(match.Groups[1].Value, out var line))
                max = Math.Max(max, line);
        }

        return max;
    }

    private string AccountLineTitle(int line)
    {
        var account = _phone?.Accounts.FirstOrDefault(x => x.Line == line);
        var label = account == null
            ? string.Empty
            : FirstNonEmpty(account.Label, account.DisplayName, account.UserName, account.RegisterName);

        var title = string.IsNullOrWhiteSpace(label)
            ? $"Аккаунт {line}"
            : $"Аккаунт {line}: {label}";

        return _phone?.DefaultAccountLine == line ? $"{title} (по умолчанию)" : title;
    }

    private void OnAccountLineChanged(ChangeEventArgs e)
    {
        if (_phone == null)
            return;

        SaveCurrentConfigToPhoneCache();

        if (int.TryParse(e.Value?.ToString(), out var line) && line > 0)
            _selectedAccountLine = line;

        ApplyStoredConfig(GetStoredConfigForLine(_selectedAccountLine, _phone.ConfigFields));
        ApplyStatusToConfigDefaults();
        _loadedConfigValues = CurrentConfigValues();
    }

    private Dictionary<string, string> GetStoredConfigForLine(int line, Dictionary<string, string> values)
    {
        var result = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
        var prefix = LineStoragePrefix(line);

        foreach (var item in values)
        {
            if (item.Key.StartsWith(prefix, StringComparison.OrdinalIgnoreCase))
                result[item.Key[prefix.Length..]] = item.Value;
        }

        if (line == 1)
        {
            foreach (var key in ConfigToCfgKey.Keys)
            {
                if (!result.ContainsKey(key) && values.TryGetValue(key, out var value))
                    result[key] = value;
            }
        }

        return result;
    }

    private static string LineStoragePrefix(int line) => line <= 1 ? "Line1." : $"Line{line}.";

    private static string FirstNonEmpty(params string?[] values) =>
        values.FirstOrDefault(x => !string.IsNullOrWhiteSpace(x)) ?? string.Empty;

    private static string[] AccountKeys(int line, string field)
    {
        var index = line - 1;
        return field switch
        {
            "enable" => [$"AccountEnable.{line}", $"data.formData.AccountEnable.{line}", $"account.{line}.enable"],
            "label" => [$"AccountLabel.{line}", $"data.formData.AccountLabel.{line}", $"account.{line}.label", $"account.info.{line}.label", $"account.info.{index}.label", $"data.{line}.label", $"data.{index}.label"],
            "display" => [$"AccountDisplayName.{line}", $"data.formData.AccountDisplayName.{line}", $"account.{line}.display_name", $"account.info.{line}.displayName", $"account.info.{index}.displayName", $"data.{line}.displayName", $"data.{index}.displayName"],
            "register" => [$"AccountRegisterName.{line}", $"data.formData.AccountRegisterName.{line}", $"account.{line}.auth_name", $"account.info.{line}.registerName", $"account.info.{index}.registerName", $"data.{line}.registerName", $"data.{index}.registerName"],
            "user" => [$"AccountUserName.{line}", $"data.formData.AccountUserName.{line}", $"account.{line}.user_name", $"account.info.{line}.userName", $"account.info.{index}.userName", $"data.{line}.userName", $"data.{index}.userName"],
            "server1" => [$"AccountServerAddr1.{line}", $"data.formData.AccountServerAddr1.{line}", $"AccountServerAddr.{line}.1", $"data.formData.AccountServerAddr.{line}.1", $"account.{line}.sip_server.1.address", $"account.info.{line}.sipServer", $"account.info.{index}.sipServer", $"data.{line}.sipServer", $"data.{index}.sipServer"],
            "port1" => [$"AccountServerPort1.{line}", $"data.formData.AccountServerPort1.{line}", $"AccountServerPort.{line}.1", $"data.formData.AccountServerPort.{line}.1", $"account.{line}.sip_server.1.port"],
            "transport1" => [$"AccountServerTransport1.{line}", $"data.formData.AccountServerTransport1.{line}", $"AccountServerTransport.{line}.1", $"data.formData.AccountServerTransport.{line}.1", $"account.{line}.sip_server.1.transport_type"],
            "expires1" => [$"AccountServerExpires1.{line}", $"data.formData.AccountServerExpires1.{line}", $"AccountServerExpires.{line}.1", $"data.formData.AccountServerExpires.{line}.1", $"account.{line}.sip_server.1.expires"],
            "retry1" => [$"AccountServerRetryCounts1.{line}", $"data.formData.AccountServerRetryCounts1.{line}", $"AccountServerRetryCounts.{line}.1", $"data.formData.AccountServerRetryCounts.{line}.1", $"account.{line}.sip_server.1.retry_counts"],
            "server2" => [$"AccountServerAddr2.{line}", $"data.formData.AccountServerAddr2.{line}", $"AccountServerAddr.{line}.2", $"data.formData.AccountServerAddr.{line}.2", $"account.{line}.sip_server.2.address"],
            "port2" => [$"AccountServerPort2.{line}", $"data.formData.AccountServerPort2.{line}", $"AccountServerPort.{line}.2", $"data.formData.AccountServerPort.{line}.2", $"account.{line}.sip_server.2.port"],
            "transport2" => [$"AccountServerTransport2.{line}", $"data.formData.AccountServerTransport2.{line}", $"AccountServerTransport.{line}.2", $"data.formData.AccountServerTransport.{line}.2", $"account.{line}.sip_server.2.transport_type"],
            "expires2" => [$"AccountServerExpires2.{line}", $"data.formData.AccountServerExpires2.{line}", $"AccountServerExpires.{line}.2", $"data.formData.AccountServerExpires.{line}.2", $"account.{line}.sip_server.2.expires"],
            "retry2" => [$"AccountServerRetryCounts2.{line}", $"data.formData.AccountServerRetryCounts2.{line}", $"AccountServerRetryCounts.{line}.2", $"data.formData.AccountServerRetryCounts.{line}.2", $"account.{line}.sip_server.2.retry_counts"],
            _ => []
        };
    }

    private void ApplyAccountConfig(Dictionary<string, string> fields)
    {
        var line = _selectedAccountLine;

        _lineEnabled = BoolValue(fields, true, AccountKeys(line, "enable"));
        _lineLabel = ValueFrom(fields, _lineLabel, AccountKeys(line, "label"));
        _displayName = ValueFrom(fields, _displayName, AccountKeys(line, "display"));
        _registerName = ValueFrom(fields, _registerName, AccountKeys(line, "register"));
        _userName = ValueFrom(fields, _userName, AccountKeys(line, "user"));

        _sipServer1 = ValueFrom(fields, _sipServer1, AccountKeys(line, "server1"));
        _sipPort1 = IntValue(fields, _sipPort1, AccountKeys(line, "port1"));
        _transport1 = TransportValue(fields, _transport1, AccountKeys(line, "transport1"));
        _serverTimeout1 = IntValue(fields, _serverTimeout1, AccountKeys(line, "expires1"));
        _retryCount1 = IntValue(fields, _retryCount1, AccountKeys(line, "retry1"));

        _sipServer2 = ValueFrom(fields, _sipServer2, AccountKeys(line, "server2"));
        _sipPort2 = IntValue(fields, _sipPort2, AccountKeys(line, "port2"));
        _transport2 = TransportValue(fields, _transport2, AccountKeys(line, "transport2"));
        _serverTimeout2 = IntValue(fields, _serverTimeout2, AccountKeys(line, "expires2"));
        _retryCount2 = IntValue(fields, _retryCount2, AccountKeys(line, "retry2"));

        _password = string.Empty;
        _loadedConfigValues = CurrentConfigValues();
    }

    private async Task MergeStatusFieldsForConfig(Dictionary<string, string> fields, string username, string password)
    {
        if (_phone == null)
            return;

        try
        {
            if (IsModernConfigPhone())
            {
                var modernStatus = await ModernApiClient.GetStatusAsync(_phone.IpAddress, username, password);
                ApplyModernStatus(modernStatus);
            }
            else
            {
                var status = await StatusClient.GetStatusAsync(_phone.IpAddress, username, password);
                _phone.StatusFields = status.Fields;
            }

            if (_phone.StatusFields is { Count: > 0 } statusFields)
            {
                foreach (var item in statusFields)
                {
                    if (!fields.ContainsKey(item.Key) ||
                        item.Key.Equals("Account", StringComparison.OrdinalIgnoreCase) ||
                        item.Key.Equals("Account 1", StringComparison.OrdinalIgnoreCase))
                    {
                        fields[item.Key] = item.Value;
                    }
                }
            }
        }
        catch
        {
            // Status data is optional for config editing.
        }
    }

    private async Task<Dictionary<string, string>> LoadLegacyAccountConfigFields(string username, string password)
    {
        if (_phone == null)
            return new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);

        var fields = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);

        try
        {
            var result = await StatusClient.GetAccountConfigAsync(_phone.IpAddress, username, password);
            foreach (var item in result.Fields)
                fields[item.Key] = item.Value;
        }
        catch
        {
            // Old T3x phones do not always expose account edit fields through the JSON API.
        }

        var cfgBytes = await ConfigManager.DownloadConfigAsync(_phone.IpAddress, username, password);
        var cfgText = System.Text.Encoding.UTF8.GetString(cfgBytes);
        foreach (var item in ParseCfgFields(cfgText))
            fields[item.Key] = item.Value;

        return fields;
    }

    private static Dictionary<string, string> ParseCfgFields(string cfgText)
    {
        var fields = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);

        foreach (var rawLine in cfgText.Split('\n'))
        {
            var line = rawLine.Trim();
            if (string.IsNullOrWhiteSpace(line) || line.StartsWith('#') || !line.Contains('='))
                continue;

            var parts = line.Split('=', 2);
            var key = parts[0].Trim();
            var value = parts.Length > 1 ? parts[1].Trim() : string.Empty;

            if (!string.IsNullOrWhiteSpace(key))
                fields[key] = value;
        }

        return fields;
    }

    private async Task SaveConfig()
    {
        if (_phone == null) return;

        var creds = Credentials.GetAdminCredentials();
        if (creds == null)
        {
            _configMessage = "Требуется admin-авторизация для сохранения конфигурации.";
            return;
        }

        var changes = BuildChangedCfgValues();
        if (changes.Count == 0)
        {
            _configMessage = "Изменений нет.";
            return;
        }

        _savingConfig = true;
        _configMessage = "Формирование и отправка delta .cfg...";
        await InvokeAsync(StateHasChanged);

        try
        {
            var generatedPath = await SaveDeltaCfgAsync(changes);
            var result = await ImportGeneratedCfgAsync(generatedPath, creds.Value.username, creds.Value.password);

            if (result.Success)
            {
                if (_selectedAccountLine == ResolvePrimaryAccountLine())
                    _phone.Account = FirstNonEmpty(_lineLabel, _userName, _registerName);

                SaveCurrentConfigToPhoneCache();
                Store.Upsert(_phone);
                await Store.SaveAsync();
                LogPhoneAction("Сохранение конфигурации аккаунта", $"Аккаунт: {_selectedAccountLine}. Изменений: {changes.Count}. Файл: {generatedPath}");
                _loadedConfigValues = CurrentConfigValues();
                _configMessage = $"Изменения отправлены в телефон. Delta .cfg: {generatedPath}";
            }
            else
            {
                _configMessage = $"Ошибка сохранения: {result.Message}";
            }
        }
        catch (Exception ex)
        {
            _configMessage = $"Ошибка сохранения: {GetUsefulErrorMessage(ex)}";
        }
        finally
        {
            _savingConfig = false;
            await InvokeAsync(StateHasChanged);
        }
    }

