            _phone.MacAddress = mac;

        if (string.IsNullOrWhiteSpace(_phone.SerialNumber) && TryValue(out var serial, "Device ID", "Machine ID", "ID СѓСЃС‚СЂРѕР№СЃС‚РІР°"))
            _phone.SerialNumber = serial;

        _rawHtmlPreview = result.RawHtml[..Math.Min(2000, result.RawHtml.Length)];
    }

    private void ApplyModernStatus(PhoneStatus status)
    {
        if (_phone == null)
            return;

        var fields = new Dictionary<string, string>(status.RawValues, StringComparer.OrdinalIgnoreCase);
        var resolvedModel = ModelResolver.Resolve(status.FirmwareVersion, status.HardwareVersion);

        AddField(fields, "Firmware Version", status.FirmwareVersion);
        AddField(fields, "FirmwareVersion", status.FirmwareVersion);
        AddField(fields, "Build Version", status.HardwareVersion);
        AddField(fields, "Build", status.HardwareVersion);
        AddField(fields, "Model", status.Model ?? resolvedModel);
        AddField(fields, "MAC Address", status.MacAddress);
        AddField(fields, "MACAddress", status.MacAddress);
        AddField(fields, "Device ID", status.DeviceId);
        AddField(fields, "Machine ID", status.DeviceId);
        AddField(fields, "WAN Port Type", status.NetworkMode);
        AddField(fields, "Internet Port Type", status.NetworkMode);
        AddField(fields, "IPv4 WAN IP Address", status.IpAddressV4);
        AddField(fields, "WAN IP Address", status.IpAddressV4);
        AddField(fields, "IP Address", status.IpAddressV4);
        AddField(fields, "Subnet Mask", status.SubnetMask);
        AddField(fields, "IPv4 Gateway", status.Gateway);
        AddField(fields, "Gateway", status.Gateway);
        AddField(fields, "IPv4 Primary DNS", status.PrimaryDns);
        AddField(fields, "Primary DNS", status.PrimaryDns);
        AddField(fields, "IPv4 Secondary DNS", status.SecondaryDns);
        AddField(fields, "Secondary DNS", status.SecondaryDns);
        AddField(fields, "VLAN ID", status.VlanId);
        AddField(fields, "WAN Port Status", status.WanPortStatus);
        AddField(fields, "PC Port Status", status.PcPortStatus);
        AddField(fields, "Device Type", status.DeviceType);
        AddField(fields, "Current Time", status.CurrentTime);
        AddField(fields, "Uptime", FormatUptime(status.Uptime));

        SyncAccountsFromStatus(status.Accounts);

        foreach (var account in status.Accounts.OrderBy(x => x.Line))
        {
            AddField(fields, $"Account {account.Line}", FormatAccount(account));
        }

        var firstAccount = status.Accounts.OrderBy(x => x.Line).FirstOrDefault();
        if (firstAccount != null)
        {
            var accountText = FormatAccount(firstAccount);
            AddField(fields, "Account", firstAccount.Number ?? accountText);
            _phone.Account = firstAccount.Number ?? _phone.Account;
        }

        _phone.StatusFields = fields;
        _phone.IsOnline = true;
        _phone.LastSeen = DateTime.Now;

        if (!string.IsNullOrWhiteSpace(status.Model ?? resolvedModel))
            _phone.Model = status.Model ?? resolvedModel;

        if (!string.IsNullOrWhiteSpace(status.MacAddress))
            _phone.MacAddress = status.MacAddress;

        if (!string.IsNullOrWhiteSpace(status.DeviceId))
            _phone.SerialNumber = status.DeviceId;
    }

    private void SyncAccountsFromStatus(IEnumerable<AccountStatus> accounts)
    {
        if (_phone == null)
            return;

        foreach (var account in accounts)
        {
            var line = account.Line <= 0 ? 1 : account.Line;
            var target = GetOrCreateAccount(line);
            target.Label = account.Label ?? target.Label;
            target.DisplayName = account.Label ?? target.DisplayName;
            target.RegisterName = account.Number ?? target.RegisterName;
            target.UserName = account.Number ?? target.UserName;
            target.SipServer1 = account.Server ?? target.SipServer1;
            target.IsDefault = account.IsDefault;
        }

        var defaultLine = _phone.Accounts.FirstOrDefault(x => x.IsDefault)?.Line;
        if (defaultLine is > 0)
            _phone.DefaultAccountLine = defaultLine;

        NormalizeAccountSummary();
    }

    private void SyncAccountsFromConfigFields(Dictionary<string, string> fields)
    {
        if (_phone == null)
            return;

        var maxLine = Math.Max(DetectedMaxAccountLine(), DetectMaxAccountLine(fields));
        for (var line = 1; line <= Math.Min(maxLine, 16); line++)
        {
            if (!HasAccountData(fields, line) && _phone.Accounts.All(x => x.Line != line))
                continue;

            var account = GetOrCreateAccount(line);
            account.Enabled = BoolValue(fields, account.Enabled, AccountKeys(line, "enable"));
            account.Label = ValueFrom(fields, account.Label, AccountKeys(line, "label"));
            account.DisplayName = ValueFrom(fields, account.DisplayName, AccountKeys(line, "display"));
            account.RegisterName = ValueFrom(fields, account.RegisterName, AccountKeys(line, "register"));
            account.UserName = ValueFrom(fields, account.UserName, AccountKeys(line, "user"));
            account.SipServer1 = ValueFrom(fields, account.SipServer1, AccountKeys(line, "server1"));
            account.SipPort1 = IntValue(fields, account.SipPort1, AccountKeys(line, "port1"));
            account.Transport1 = TransportValue(fields, account.Transport1, AccountKeys(line, "transport1"));
            account.ServerTimeout1 = IntValue(fields, account.ServerTimeout1, AccountKeys(line, "expires1"));
            account.RetryCount1 = IntValue(fields, account.RetryCount1, AccountKeys(line, "retry1"));
            account.SipServer2 = ValueFrom(fields, account.SipServer2, AccountKeys(line, "server2"));
            account.SipPort2 = IntValue(fields, account.SipPort2, AccountKeys(line, "port2"));
            account.Transport2 = TransportValue(fields, account.Transport2, AccountKeys(line, "transport2"));
            account.ServerTimeout2 = IntValue(fields, account.ServerTimeout2, AccountKeys(line, "expires2"));
            account.RetryCount2 = IntValue(fields, account.RetryCount2, AccountKeys(line, "retry2"));
        }

        var defaultLine = IntValue(
            fields,
            _phone.DefaultAccountLine ?? 0,
            "DefaultAccount",
            "AccountDefault",
            "DefaultAccountLine",
            "PhoneDefaultAccount",
            "account.default",
            "account.default_line");

        if (defaultLine > 0)
            _phone.DefaultAccountLine = defaultLine;

        NormalizeAccountSummary();
    }

    private static int DetectMaxAccountLine(Dictionary<string, string> fields)
    {
        var max = 1;
        foreach (var key in fields.Keys)
        {
            var match = System.Text.RegularExpressions.Regex.Match(key, @"(?:Account\w*\.|account\.|Line)(\d+)");
            if (match.Success && int.TryParse(match.Groups[1].Value, out var line))
                max = Math.Max(max, line);
        }

        return max;
    }

    private static bool HasAccountData(Dictionary<string, string> fields, int line) =>
        AccountKeys(line, "label")
            .Concat(AccountKeys(line, "display"))
            .Concat(AccountKeys(line, "register"))
            .Concat(AccountKeys(line, "user"))
            .Concat(AccountKeys(line, "server1"))
            .Any(key => fields.TryGetValue(key, out var value) && !string.IsNullOrWhiteSpace(value));

    private void SyncCurrentFormToAccountCache()
    {
        if (_phone == null)
            return;

        var account = GetOrCreateAccount(_selectedAccountLine);
        account.Enabled = _lineEnabled;
        account.Label = NormalizeCfgValue(_lineLabel);
        account.DisplayName = NormalizeCfgValue(_displayName);
        account.RegisterName = NormalizeCfgValue(_registerName);
        account.UserName = NormalizeCfgValue(_userName);
        account.SipServer1 = NormalizeCfgValue(_sipServer1);
        account.SipPort1 = _sipPort1;
        account.Transport1 = _transport1;
        account.ServerTimeout1 = _serverTimeout1;
        account.RetryCount1 = _retryCount1;
        account.SipServer2 = NormalizeCfgValue(_sipServer2);
        account.SipPort2 = _sipPort2;
        account.Transport2 = _transport2;
        account.ServerTimeout2 = _serverTimeout2;
        account.RetryCount2 = _retryCount2;

        NormalizeAccountSummary();
    }

    private PhoneAccountInfo GetOrCreateAccount(int line)
    {
        if (_phone == null)
            throw new InvalidOperationException("Phone is not loaded.");

        var account = _phone.Accounts.FirstOrDefault(x => x.Line == line);
        if (account != null)
            return account;

        account = new PhoneAccountInfo { Line = line };
        _phone.Accounts.Add(account);
        _phone.Accounts = _phone.Accounts.OrderBy(x => x.Line).ToList();
        return account;
    }

    private int ResolvePrimaryAccountLine()
    {
        if (_phone?.DefaultAccountLine is > 0)
            return _phone.DefaultAccountLine.Value;

        return _phone?.Accounts
            .Where(x => x.Enabled || !string.IsNullOrWhiteSpace(x.Label) || !string.IsNullOrWhiteSpace(x.UserName))
            .OrderBy(x => x.Line)
            .Select(x => x.Line)
            .FirstOrDefault(1) ?? 1;
    }

    private void NormalizeAccountSummary()
    {
        if (_phone == null)
            return;

        foreach (var account in _phone.Accounts)
            account.IsDefault = _phone.DefaultAccountLine == account.Line;

        var primaryLine = ResolvePrimaryAccountLine();
        var primary = _phone.Accounts.FirstOrDefault(x => x.Line == primaryLine);
        var primaryText = primary == null
            ? string.Empty
            : FirstNonEmpty(primary.UserName, primary.RegisterName, primary.Label, primary.DisplayName);

        _phone.Account = string.IsNullOrWhiteSpace(primaryText) ? "-" : primaryText;
    }

    private static void AddField(Dictionary<string, string> fields, string key, string? value)
    {
        if (!string.IsNullOrWhiteSpace(value))
            fields[key] = value;
    }

    private static string FormatAccount(AccountStatus account)
    {
        var number = account.Number ?? account.Label ?? $"Account {account.Line}";
        if (!string.IsNullOrWhiteSpace(account.Server) && !number.Contains('@'))
            number = $"{number}@{account.Server}";

        return string.IsNullOrWhiteSpace(account.Status)
            ? number
            : $"{number} : {account.Status}";
    }

    private static string? FormatUptime(int? totalSeconds)
    {
        if (!totalSeconds.HasValue)
            return null;

        var time = TimeSpan.FromSeconds(totalSeconds.Value);
        return time.Days > 0
            ? $"{time.Days} дни {time.Hours:00}:{time.Minutes:00}"
            : $"{(int)time.TotalHours:00}:{time.Minutes:00}";
    }

    private static string GetUsefulErrorMessage(Exception ex)
    {
        var messages = new List<string>();
        for (var current = ex; current != null; current = current.InnerException)
        {
            if (!string.IsNullOrWhiteSpace(current.Message) && !messages.Contains(current.Message))
                messages.Add(current.Message);
        }

        return string.Join(" / ", messages);
    }

    private void ApplyStatusToConfigDefaults()
    {
        if ((_phone?.ConfigFields?.Count ?? 0) > 0)
            return;

        if (_phone?.StatusFields is { Count: > 0 } fields)
        {
            var line = _selectedAccountLine;
            var label = ValueFrom(fields, string.Empty, AccountKeys(line, "label"));
            var displayName = ValueFrom(fields, string.Empty, AccountKeys(line, "display"));
            var registerName = ValueFrom(fields, string.Empty, AccountKeys(line, "register"));
            var userName = ValueFrom(fields, string.Empty, AccountKeys(line, "user"));
            var sipServer = ValueFrom(fields, string.Empty, AccountKeys(line, "server1"));

            if (!string.IsNullOrWhiteSpace(label))
                _lineLabel = label;

            if (!string.IsNullOrWhiteSpace(displayName))
                _displayName = displayName;

            if (!string.IsNullOrWhiteSpace(registerName))
                _registerName = registerName;

            if (!string.IsNullOrWhiteSpace(userName))
                _userName = userName;

            if (!string.IsNullOrWhiteSpace(sipServer))
                _sipServer1 = sipServer;
        }

        if (TryValue(out var account, "Account 1", "Account", "Аккаунт 1", "Аккаунт"))
        {
            var extension = ExtractAccount(account);
            if (!string.IsNullOrWhiteSpace(extension))
            {
                if (string.IsNullOrWhiteSpace(_lineLabel))
                    _lineLabel = extension;

                if (string.IsNullOrWhiteSpace(_displayName))
                    _displayName = extension;

                if (string.IsNullOrWhiteSpace(_registerName))
                    _registerName = extension;

                if (string.IsNullOrWhiteSpace(_userName))
                    _userName = extension;
            }
        }
    }

    private async Task LoadAccountConfigFromWeb()
    {
        if (_phone == null) return;

        var creds = Credentials.GetAdminCredentials();
        if (creds == null)
        {
            _configMessage = "Требуется admin-авторизация для загрузки конфигурации.";
            return;
        }

        _loadingAccountConfig = true;
        _configMessage = "Загрузка параметров аккаунта...";
        await InvokeAsync(StateHasChanged);

        try
        {
            var fields = IsModernConfigPhone()
                ? (await ModernApiClient.GetAccountConfigAsync(_phone.IpAddress, creds.Value.username, creds.Value.password)).Fields
                : await LoadLegacyAccountConfigFields(creds.Value.username, creds.Value.password);

            await MergeStatusFieldsForConfig(fields, creds.Value.username, creds.Value.password);
            SyncAccountsFromConfigFields(fields);
            SaveLoadedAccountConfigToPhoneCache(fields);
            _selectedAccountLine = AccountLineOptions.Contains(_selectedAccountLine)
                ? _selectedAccountLine
                : ResolveInitialAccountLine();
            ApplyAccountConfig(fields);
            SaveCurrentConfigToPhoneCache();
            Store.Upsert(_phone);
            await Store.SaveAsync();
            LogPhoneAction("Загрузка конфигурации аккаунта", $"Аккаунт: {_selectedAccountLine}");
            _configMessage = "Параметры аккаунта загружены из телефона. Пароль не подставляю в форму из соображений безопасности.";
        }
        catch (Exception ex)
        {
            _configMessage = $"Ошибка загрузки конфигурации аккаунта: {ex.Message}";
        }
        finally
        {
            _loadingAccountConfig = false;
            await InvokeAsync(StateHasChanged);
        }
    }

