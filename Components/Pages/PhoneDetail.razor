    private void SelectExpansionPage(int page)
    {
        _selectedExpansionPage = Math.Clamp(page, 1, 3);
        EnsureExpansionKeys();
    }

    private IEnumerable<ExpansionKeyInfo> ExpansionPageKeys(bool odd)
    {
        EnsureExpansionKeys();
        var start = ((_selectedExpansionPage - 1) * 20) + 1;
        var end = start + 19;
        return _phone?.ExpansionKeys
            .Where(x => x.Index >= start && x.Index <= end && (x.Index % 2 == (odd ? 1 : 0)))
            .OrderBy(x => x.Index) ?? Enumerable.Empty<ExpansionKeyInfo>();
    }

    private void EnsureExpansionKeys()
    {
        if (_phone == null)
            return;

        for (var index = 1; index <= 60; index++)
        {
            if (_phone.ExpansionKeys.Any(x => x.Index == index))
                continue;

            _phone.ExpansionKeys.Add(new ExpansionKeyInfo
            {
                Index = index,
                Id = (index - 1).ToString(),
                KeyName = $"Key{index}",
                Type = "13",
                Line = "0"
            });
        }

        _phone.ExpansionKeys = _phone.ExpansionKeys.OrderBy(x => x.Index).ToList();
    }

    private async Task SaveExpansionPanel()
    {
        if (_phone == null)
            return;

        var creds = Credentials.GetAdminCredentials();
        if (creds == null)
        {
            _expansionPanelMessage = "Требуется админ-режим для сохранения панели расширения.";
            return;
        }

        var changes = BuildExpansionChangedCfgValues();
        if (changes.Count == 0)
        {
            _expansionPanelMessage = "Изменений на панели расширения нет.";
            return;
        }

        _savingExpansionPanel = true;
        _expansionPanelMessage = "Формирование и отправка delta .cfg для панели расширения...";
        await InvokeAsync(StateHasChanged);

        try
        {
            var path = await SaveExpansionDeltaCfgAsync(changes);
            var result = await ModernApiClient.ImportCfgAsync(_phone.IpAddress, creds.Value.username, creds.Value.password, path);
            if (result.Success)
            {
                NormalizeExpansionKeysForSpeedDial();
                _loadedExpansionValues = CurrentExpansionValues();
                Store.Upsert(_phone);
                await Store.SaveAsync();
                LogPhoneAction("Сохранение панели расширения", $"Изменений: {changes.Count}. Файл: {path}");
                _expansionPanelMessage = $"Панель расширения сохранена. Delta .cfg: {path}";
            }
            else
            {
                _expansionPanelMessage = $"Ошибка сохранения панели расширения: {result.Message}";
            }
        }
        catch (Exception ex)
        {
            _expansionPanelMessage = $"Ошибка сохранения панели расширения: {GetUsefulErrorMessage(ex)}";
        }
        finally
        {
            _savingExpansionPanel = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void NormalizeExpansionKeysForSpeedDial()
    {
        if (_phone == null)
            return;

        foreach (var key in _phone.ExpansionKeys)
        {
            key.Line = "0";
            key.Type = "13";
        }
    }

